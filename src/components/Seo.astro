---
interface Props {
  title: string;
  description: string;
  ogImage?: string;
  jsonLd?: object | object[];
}
const { title, description, ogImage = '/images/og.webp', jsonLd } = Astro.props;

const pathname = Astro.url.pathname;

// Compute the es/en counterpart paths for hreflang.
// es lives at root ("/", "/about", ...); en is prefixed ("/en/", "/en/about", ...).
const isEnglish = pathname === '/en' || pathname.startsWith('/en/');

let esPath: string;
let enPath: string;
if (isEnglish) {
  enPath = pathname;
  esPath = pathname.replace(/^\/en/, '') || '/';
} else {
  esPath = pathname;
  enPath = pathname === '/' ? '/en/' : '/en' + pathname;
}

const esURL = new URL(esPath, Astro.site).toString();
const enURL = new URL(enPath, Astro.site).toString();
const canonicalURL = new URL(pathname, Astro.site).toString();
const ogImageURL = new URL(ogImage, Astro.site).toString();

const ogLocale = isEnglish ? 'en_US' : 'es_ES';
---
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />

<!-- hreflang alternates -->
<link rel="alternate" hreflang="es" href={esURL} />
<link rel="alternate" hreflang="en" href={enURL} />
<link rel="alternate" hreflang="x-default" href={esURL} />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:image:alt" content={title} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content={ogLocale} />
<meta property="og:site_name" content="Eulogio Albalat" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageURL} />
<meta name="twitter:image:alt" content={title} />

<!-- Structured data -->
{jsonLd && <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
