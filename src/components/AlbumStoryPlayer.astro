---
import AlbumCard from '@/components/AlbumCard.astro';
import MediaEmbedFacade from '@/components/MediaEmbedFacade.astro';
import type { Album } from '@/data/discography';

interface Props {
  albums: Album[];
  locale: 'es' | 'en';
}

const { albums, locale } = Astro.props;
const selected = albums.find((album) => album.featured) ?? albums[0];
const copy = {
  es: {
    eyebrow: 'Archivo sonoro',
    title: 'Discografia como estanteria viva',
    intro: 'Cada album funciona como un capitulo: funda, repertorio, enlaces y un reproductor que espera hasta que decidas abrirlo.',
    console: 'Consola de escucha',
    selected: 'Seleccionado ahora',
    tracklist: 'Pistas destacadas',
    listen: 'Escuchar',
    spotify: 'Spotify',
    appleMusic: 'Apple Music',
    youtube: 'YouTube',
    sleeve: 'Funda provisional',
    timeline: 'Linea de albums',
  },
  en: {
    eyebrow: 'Sound archive',
    title: 'Discography as a living record shelf',
    intro: 'Each album acts as a chapter: sleeve, repertoire, links, and a player that waits until you choose to open it.',
    console: 'Listening console',
    selected: 'Now selected',
    tracklist: 'Featured tracks',
    listen: 'Listen',
    spotify: 'Spotify',
    appleMusic: 'Apple Music',
    youtube: 'YouTube',
    sleeve: 'Temporary sleeve',
    timeline: 'Album timeline',
  },
}[locale];
---
<section class="relative overflow-hidden px-6 pb-20 pt-32 md:px-10 md:pb-28 md:pt-40" data-album-story>
  <script is:inline set:html={`window.__albalatAlbums = ${JSON.stringify(albums)}`}></script>
  <div class="pointer-events-none absolute inset-0 opacity-70" aria-hidden="true" data-parallax-y="0.3">
    <div class="absolute inset-x-0 top-0 h-[42rem] bg-[radial-gradient(circle_at_16%_10%,rgba(198,146,62,.24),transparent_28%),radial-gradient(circle_at_88%_18%,rgba(26,103,95,.24),transparent_30%),linear-gradient(180deg,rgba(93,26,45,.16),transparent_72%)]"></div>
    <div class="absolute inset-x-0 top-24 h-px bg-ink/10"></div>
  </div>

  <div class="relative mx-auto max-w-7xl">
    <div class="max-w-4xl">
      <p class="font-mono text-xs font-medium uppercase tracking-wide text-accent">{copy.eyebrow}</p>
      <h1 class="mt-6 font-display text-5xl font-light leading-tight text-ink md:text-7xl">
        {copy.title}
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-ink-muted md:text-xl md:leading-9">
        {copy.intro}
      </p>
    </div>

    <div class="mt-14 grid gap-10 lg:grid-cols-[minmax(320px,420px)_minmax(0,1fr)] lg:items-start">
      <aside class="lg:sticky lg:top-28" aria-label={copy.console}>
        <div class="border border-ink/12 bg-[#12100e]/95 p-4 shadow-2xl shadow-black/35">
          <div class="relative overflow-hidden border border-ink/10 bg-[#080706] p-4">
            <div class="absolute -right-20 -top-24 size-64 rounded-full border border-ink/10 bg-[conic-gradient(from_20deg,#070707,#27221a,#070707,#571d2b,#070707)]" aria-hidden="true"></div>
            <div class="relative">
              <p class="font-mono text-[0.68rem] uppercase tracking-wide text-accent">{copy.selected}</p>
              <div class="mt-4 grid grid-cols-[112px_minmax(0,1fr)] gap-4">
                <img
                  src={selected?.cover}
                  alt={`TODO-ASSET cover placeholder for ${selected?.title}`}
                  width="224"
                  height="224"
                  class="aspect-square w-full border border-ink/10 object-cover"
                  data-console-cover
                />
                <div class="min-w-0">
                  <p class="font-mono text-xs uppercase tracking-wide text-ink-muted" data-console-year>{selected?.year}</p>
                  <h2 class="mt-2 text-2xl font-medium leading-tight text-ink" data-console-title>{selected?.title}</h2>
                  <p class="mt-3 text-sm leading-6 text-ink-muted" data-console-label>{selected?.label ?? copy.sleeve}</p>
                </div>
              </div>
              <div class="mt-5 h-2 overflow-hidden bg-ink/10" aria-hidden="true">
                <div class="h-full w-1/2 bg-accent transition-all duration-500" data-console-meter></div>
              </div>
            </div>
          </div>

          <div class="mt-4 grid gap-3">
            <button
              type="button"
              data-play-album={selected?.id}
              class="inline-flex items-center justify-center gap-2 border border-ink/20 bg-ink px-4 py-3 text-sm font-semibold text-stage transition-colors hover:bg-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent"
            >
              <span aria-hidden="true">▶</span>
              <span>{locale === 'es' ? 'Reproducir album' : 'Play album'}</span>
            </button>
            {selected?.embeds?.youtube && (
              <MediaEmbedFacade provider="youtube" title={`${copy.youtube}: ${selected.title}`} src={selected.embeds.youtube} locale={locale} />
            )}
          </div>
        </div>
      </aside>

      <div>
        <nav class="album-rail -mx-6 flex gap-4 overflow-x-auto px-6 pb-5 lg:mx-0 lg:grid lg:overflow-visible lg:px-0" aria-label={copy.timeline}>
          {albums.map((album, index) => <AlbumCard album={album} locale={locale} index={index} />)}
        </nav>

        <div class="mt-8 space-y-8">
          {albums.map((album, index) => (
            <article
              id={album.id}
              class="album-chapter scroll-mt-28 border border-ink/10 bg-ink/[0.035] p-5 md:p-7"
              data-album-section={album.id}
              data-album-title={album.title}
              data-album-year={album.year}
              data-album-cover={album.cover}
              data-album-label={album.label ?? copy.sleeve}
            >
              <div class="grid gap-7 md:grid-cols-[180px_minmax(0,1fr)]">
                <figure class="relative">
                  <img
                    src={album.cover}
                    alt={`TODO-ASSET cover placeholder for ${album.title}`}
                    width="360"
                    height="360"
                    loading={index === 0 ? 'eager' : 'lazy'}
                    class="aspect-square w-full border border-ink/10 object-cover"
                  />
                  <figcaption class="mt-3 font-mono text-[0.68rem] uppercase tracking-wide text-ink-muted">
                    {copy.sleeve}
                  </figcaption>
                </figure>

                <div class="min-w-0">
                  <div class="flex flex-wrap items-center gap-3 font-mono text-xs uppercase tracking-wide text-accent">
                    <span>{album.year}</span>
                    {album.label && <span class="text-ink-muted">{album.label}</span>}
                  </div>
                  <h2 class="mt-4 font-display text-4xl font-light leading-tight text-ink md:text-5xl">
                    {album.title}
                  </h2>
                  <p class="mt-5 max-w-2xl text-base leading-7 text-ink-muted md:text-lg md:leading-8">
                    {album.notes[locale]}
                  </p>

                  <div class="mt-7 flex flex-wrap gap-3">
                    {album.links.spotify && <a class="music-link" href={album.links.spotify} target="_blank" rel="noreferrer">{copy.spotify}</a>}
                    {album.links.appleMusic && <a class="music-link" href={album.links.appleMusic} target="_blank" rel="noreferrer">{copy.appleMusic}</a>}
                    {album.links.youtube && <a class="music-link" href={album.links.youtube} target="_blank" rel="noreferrer">{copy.youtube}</a>}
                  </div>

                  <div class="mt-8">
                    <h3 class="font-mono text-xs uppercase tracking-wide text-ink-muted">{copy.tracklist}</h3>
                    <ol class="mt-4 divide-y divide-ink/10 border-y border-ink/10">
                      {album.tracklist.map((track, trackIndex) => (
                        <li>
                          <button
                            type="button"
                            data-play-track
                            data-album-id={album.id}
                            data-track-index={trackIndex}
                            class="track-row grid w-full grid-cols-[3ch_minmax(0,1fr)_auto] items-center gap-4 py-3 text-left text-sm text-ink/90 transition-colors hover:text-accent focus-visible:outline-none focus-visible:text-accent"
                          >
                            <span class="font-mono text-ink-muted">{track.no}</span>
                            <span class="truncate">{track.title}</span>
                            {track.duration && <span class="font-mono text-ink-muted">{track.duration}</span>}
                          </button>
                        </li>
                      ))}
                    </ol>
                  </div>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .album-card[data-active="true"] {
    border-color: rgba(198, 146, 62, 0.9);
    background: rgba(244, 239, 231, 0.1);
    transform: translateX(0.35rem);
  }

  .music-link {
    border: 1px solid rgba(244, 239, 231, 0.16);
    color: var(--ink);
    display: inline-flex;
    font-size: 0.875rem;
    font-weight: 600;
    padding: 0.7rem 0.95rem;
    transition: border-color 180ms ease, color 180ms ease, background 180ms ease;
  }

  .music-link:hover,
  .music-link:focus-visible {
    background: rgba(198, 146, 62, 0.12);
    border-color: var(--accent);
    color: var(--accent);
    outline: none;
  }

  @media (max-width: 1023px) {
    .album-card[data-active="true"] {
      transform: translateY(-0.2rem);
    }
  }

  .track-row[data-track-active="true"] {
    color: var(--accent);
  }
  .track-row[data-track-active="true"] span:first-child::before {
    content: "▶ ";
    color: var(--accent);
  }
</style>

<script>
  const initAlbumStory = () => {
    document.querySelectorAll<HTMLElement>('[data-album-story]').forEach((root) => {
      if (root.dataset.ready === 'true') return;
      root.dataset.ready = 'true';

      const cards = Array.from(root.querySelectorAll<HTMLElement>('[data-album-card]'));
      const sections = Array.from(root.querySelectorAll<HTMLElement>('[data-album-section]'));
      const cover = root.querySelector<HTMLImageElement>('[data-console-cover]');
      const title = root.querySelector<HTMLElement>('[data-console-title]');
      const year = root.querySelector<HTMLElement>('[data-console-year]');
      const label = root.querySelector<HTMLElement>('[data-console-label]');
      const meter = root.querySelector<HTMLElement>('[data-console-meter]');

      const setActive = (id: string) => {
        const section = sections.find((item) => item.dataset.albumSection === id);
        if (!section) return;

        cards.forEach((card) => {
          const active = card.dataset.albumCard === id;
          card.dataset.active = String(active);
          if (active) card.setAttribute('aria-current', 'true');
          else card.removeAttribute('aria-current');
        });

        if (cover && section.dataset.albumCover) {
          cover.src = section.dataset.albumCover;
          cover.alt = `TODO-ASSET cover placeholder for ${section.dataset.albumTitle ?? 'album'}`;
        }
        if (title) title.textContent = section.dataset.albumTitle ?? '';
        if (year) year.textContent = section.dataset.albumYear ?? '';
        if (label) label.textContent = section.dataset.albumLabel ?? '';

        const index = Math.max(0, sections.indexOf(section));
        if (meter) meter.style.width = `${((index + 1) / Math.max(sections.length, 1)) * 100}%`;

        (root as any).__onActive?.(id);
      };

      setActive(sections[0]?.dataset.albumSection ?? '');

      // --- playback wiring ---
      import('@/lib/nowPlaying').then(({ getNowPlaying, buildQueue }) => {
        import('@/lib/trackTheme').then(({ applyTheme, resolveTrackTheme }) => {
          const engine = getNowPlaying();
          const albumById = new Map<string, any>();
          (window as any).__albalatAlbums?.forEach?.((a: any) => albumById.set(a.id, a));

          root.querySelectorAll<HTMLButtonElement>('[data-play-album]').forEach((btn) => {
            btn.addEventListener('click', () => {
              const album = albumById.get(btn.dataset.playAlbum!);
              if (album) engine.load(buildQueue(album), 0);
            });
          });
          root.querySelectorAll<HTMLButtonElement>('[data-play-track]').forEach((btn) => {
            btn.addEventListener('click', () => {
              const album = albumById.get(btn.dataset.albumId!);
              if (album) engine.load(buildQueue(album), Number(btn.dataset.trackIndex));
            });
          });

          const trackButtons = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-play-track]'));
          engine.subscribe((s) => {
            trackButtons.forEach((btn) => {
              const active = !!s.track && btn.dataset.albumId === s.track.albumId
                && Number(btn.dataset.trackIndex) === s.index && s.visible;
              btn.dataset.trackActive = String(active);
            });
          });

          // Scroll fallback: tint the page to the in-view album when nothing is playing.
          const applyScrollTheme = (id: string) => {
            const album = albumById.get(id);
            if (album) applyTheme('scroll', resolveTrackTheme(album, album.tracklist[0]));
          };
          (root as any).__onActive = applyScrollTheme;
          applyScrollTheme(sections[0]?.dataset.albumSection ?? '');
        });
      });

      const observer = new IntersectionObserver((entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
        const id = (visible?.target as HTMLElement | undefined)?.dataset.albumSection;
        if (id) setActive(id);
      }, { rootMargin: '-24% 0px -46% 0px', threshold: [0.18, 0.35, 0.6] });

      sections.forEach((section) => observer.observe(section));
    });
  };

  initAlbumStory();
  document.addEventListener('astro:page-load', initAlbumStory);
</script>
