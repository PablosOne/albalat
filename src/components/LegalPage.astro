---
import Base from '@/layouts/Base.astro';
import Nav from '@/components/Nav.astro';
import type { Locale } from '@/i18n';
import { site } from '@/data/site';
import { siteConfig } from '@/config/site';

interface Props {
  locale: Locale;
  kind: 'privacy' | 'cookies';
}

const { locale, kind } = Astro.props;
const isEnglish = locale === 'en';
const homeHref = isEnglish ? '/en/' : '/';
const privacyHref = isEnglish ? '/en/privacy/' : '/privacy/';
const cookieHref = isEnglish ? '/en/cookies/' : '/cookies/';
const email = siteConfig.identity.email;
const updated = siteConfig.legal.updated[locale];

const meta = {
  es: {
    privacy: { title: `Política de privacidad - ${site.fullName}`, description: siteConfig.legal.privacyDescription.es },
    cookies: { title: `Política de cookies - ${site.fullName}`, description: siteConfig.legal.cookiesDescription.es },
  },
  en: {
    privacy: { title: `Privacy policy - ${site.fullName}`, description: siteConfig.legal.privacyDescription.en },
    cookies: { title: `Cookie policy - ${site.fullName}`, description: siteConfig.legal.cookiesDescription.en },
  },
}[locale][kind];
---

<Base locale={locale} title={meta.title} description={meta.description}>
  <Nav locale={locale} />
  <main id="main-content" class="legal-page">
    <a class="legal-back" href={homeHref}>← {isEnglish ? 'Back to the website' : 'Volver al sitio web'}</a>

    {kind === 'privacy' ? (
      <article>
        <header class="legal-hero">
          <p>{isEnglish ? 'Legal · Privacy' : 'Legal · Privacidad'}</p>
          <h1>{isEnglish ? 'Privacy policy' : 'Política de privacidad'}</h1>
          <span>{isEnglish ? 'Last updated' : 'Última actualización'} · {updated}</span>
        </header>

        {isEnglish ? (
          <div class="legal-content">
            <section><h2>1. Data controller</h2><p>The controller for personal data processed through this website is <strong>{siteConfig.identity.name}</strong>, based at {siteConfig.identity.legalAddress.en}. Contact: <a href={`mailto:${email}`}>{email}</a>.</p></section>
            <section><h2>2. Data we process and why</h2><p>When you use the contact form, we process your name, email address, inquiry type, message, and the technical data needed to deliver it. We use this information solely to answer your request and manage any relationship that follows from it.</p><p>The hosting and content-delivery service may process IP address, request time and path, browser or device information, and security indicators needed to deliver and protect the website. These technical logs are not used by the controller for advertising profiles.</p><p>If you consent to analytics, Google Analytics and Cloudflare Web Analytics may process online identifiers, device and browser information, approximate location, and usage data. If you consent to external content, YouTube, Spotify, or Apple Music may receive your IP address, browser details, and interaction data when their thumbnails or players load.</p></section>
            <section><h2>3. Legal bases</h2><p>Contact requests are processed to take steps at your request before entering into a contract and, for general inquiries, on our legitimate interest in responding. Technical delivery and security logs are processed on the legitimate interest in providing a reliable, secure website. Analytics and external media are processed only with your consent. You may withdraw consent at any time through “Cookie settings” on the privacy or cookie-policy page, without affecting prior lawful processing.</p></section>
            <section><h2>4. Service providers and transfers</h2><p>Form submissions are delivered by <a href="https://web3forms.com/privacy" target="_blank" rel="noreferrer">Web3Forms</a>. The site is hosted on <a href="https://www.cloudflare.com/privacypolicy/" target="_blank" rel="noreferrer">Cloudflare Pages</a>. Subject to your choices, it may also use <a href="https://policies.google.com/privacy" target="_blank" rel="noreferrer">Google Analytics and YouTube</a>, Cloudflare Web Analytics, <a href="https://www.spotify.com/legal/privacy-policy/" target="_blank" rel="noreferrer">Spotify</a>, and <a href="https://www.apple.com/legal/privacy/" target="_blank" rel="noreferrer">Apple Music</a>. Some providers may process data outside the European Economic Area. Where applicable, the transfer must be covered by an adequacy decision, the EU–US Data Privacy Framework, or European Commission Standard Contractual Clauses. You may request information about the safeguard used for a particular transfer by emailing the controller.</p></section>
            <section><h2>5. Retention</h2><p>Inquiries that do not lead to a contractual relationship are deleted no later than 12 months after the last exchange. If a relationship follows, the records needed for that relationship and for legal claims are retained for the applicable statutory periods. Hosting and security logs are retained only for the period required by the host's documented security and operational settings. Consent choices remain in your browser for no more than 24 months, unless you clear them or this policy version changes earlier. Analytics retention is controlled in each provider account and must match the documented internal retention schedule.</p></section>
            <section><h2>6. Your rights</h2><p>You may request access, rectification, erasure, restriction, portability, or object to processing, and you may withdraw consent at any time. Send your request to <a href={`mailto:${email}`}>{email}</a>. We may ask for information necessary to verify your identity. You also have the right to lodge a complaint with the <a href="https://www.aepd.es/" target="_blank" rel="noreferrer">Spanish Data Protection Agency (AEPD)</a>.</p></section>
            <section><h2>7. Required information and automated decisions</h2><p>Name, email address, and a message are required to submit the form; without them we cannot answer the inquiry. Providing other information is voluntary. The website does not make automated decisions or create profiles that produce legal or similarly significant effects.</p></section>
            <section><h2>8. Security and changes</h2><p>We use proportionate technical and organisational safeguards, but no internet transmission is completely risk-free. We may update this policy when the website or legal requirements change; the revision date above identifies the current version.</p></section>
          </div>
        ) : (
          <div class="legal-content">
            <section><h2>1. Responsable del tratamiento</h2><p>El responsable de los datos personales tratados a través de este sitio es <strong>{siteConfig.identity.name}</strong>, con sede en {siteConfig.identity.legalAddress.es}. Contacto: <a href={`mailto:${email}`}>{email}</a>.</p></section>
            <section><h2>2. Datos tratados y finalidades</h2><p>Al utilizar el formulario de contacto tratamos tu nombre, dirección de correo, tipo de consulta, mensaje y los datos técnicos necesarios para entregarlo. Utilizamos esta información únicamente para responder y gestionar la relación que pueda derivarse de tu solicitud.</p><p>El servicio de alojamiento y distribución de contenidos puede tratar la dirección IP, fecha y ruta de la solicitud, información del navegador o dispositivo e indicadores de seguridad necesarios para entregar y proteger el sitio. El responsable no utiliza esos registros técnicos para crear perfiles publicitarios.</p><p>Si autorizas las analíticas, Google Analytics y Cloudflare Web Analytics pueden tratar identificadores en línea, información del dispositivo y navegador, ubicación aproximada y datos de uso. Si autorizas el contenido externo, YouTube, Spotify o Apple Music pueden recibir tu dirección IP, datos del navegador e interacciones al cargar sus miniaturas o reproductores.</p></section>
            <section><h2>3. Bases jurídicas</h2><p>Las consultas se tratan para aplicar medidas precontractuales solicitadas por ti y, en consultas generales, por nuestro interés legítimo en responder. Los registros técnicos de entrega y seguridad se tratan por el interés legítimo en ofrecer un sitio fiable y seguro. Las analíticas y el contenido externo se tratan únicamente con tu consentimiento. Puedes retirarlo en cualquier momento desde «Ajustes de cookies» en la página de privacidad o de cookies, sin afectar al tratamiento lícito anterior.</p></section>
            <section><h2>4. Proveedores y transferencias</h2><p><a href="https://web3forms.com/privacy" target="_blank" rel="noreferrer">Web3Forms</a> entrega los formularios. El sitio se aloja en <a href="https://www.cloudflare.com/privacypolicy/" target="_blank" rel="noreferrer">Cloudflare Pages</a>. Según tus elecciones, también puede usar <a href="https://policies.google.com/privacy" target="_blank" rel="noreferrer">Google Analytics y YouTube</a>, Cloudflare Web Analytics, <a href="https://www.spotify.com/legal/privacy-policy/" target="_blank" rel="noreferrer">Spotify</a> y <a href="https://www.apple.com/legal/privacy/" target="_blank" rel="noreferrer">Apple Music</a>. Algunos proveedores pueden tratar datos fuera del Espacio Económico Europeo. Cuando corresponde, la transferencia debe estar cubierta por una decisión de adecuación, el Marco de Privacidad de Datos UE–EE. UU. o las Cláusulas Contractuales Tipo de la Comisión Europea. Puedes solicitar información sobre la garantía aplicada a una transferencia concreta escribiendo al responsable.</p></section>
            <section><h2>5. Conservación</h2><p>Las consultas que no den lugar a una relación contractual se eliminan como máximo 12 meses después del último intercambio. Si se inicia una relación, los datos necesarios para gestionarla y atender posibles reclamaciones se conservan durante los plazos legales aplicables. Los registros de alojamiento y seguridad se conservan solo durante el periodo previsto en la configuración operativa y de seguridad documentada del proveedor. Tus preferencias permanecen en el navegador un máximo de 24 meses, salvo que las borres o cambie antes esta política. La conservación analítica se controla en la cuenta de cada proveedor y debe coincidir con el calendario interno de conservación documentado.</p></section>
            <section><h2>6. Tus derechos</h2><p>Puedes solicitar acceso, rectificación, supresión, limitación, portabilidad u oposición, y retirar tu consentimiento en cualquier momento. Escribe a <a href={`mailto:${email}`}>{email}</a>. Podremos pedir la información necesaria para verificar tu identidad. También puedes reclamar ante la <a href="https://www.aepd.es/" target="_blank" rel="noreferrer">Agencia Española de Protección de Datos (AEPD)</a>.</p></section>
            <section><h2>7. Información obligatoria y decisiones automatizadas</h2><p>El nombre, el correo electrónico y un mensaje son necesarios para enviar el formulario; sin ellos no podemos responder a la consulta. Facilitar otros datos es voluntario. El sitio no adopta decisiones automatizadas ni elabora perfiles que produzcan efectos jurídicos o similares significativos.</p></section>
            <section><h2>8. Seguridad y cambios</h2><p>Aplicamos medidas técnicas y organizativas proporcionadas, aunque ninguna transmisión por internet está libre de riesgo. Podemos actualizar esta política si cambia el sitio o la normativa; la fecha superior identifica la versión vigente.</p></section>
          </div>
        )}
      </article>
    ) : (
      <article>
        <header class="legal-hero">
          <p>{isEnglish ? 'Legal · Storage' : 'Legal · Almacenamiento'}</p>
          <h1>{isEnglish ? 'Cookie policy' : 'Política de cookies'}</h1>
          <span>{isEnglish ? 'Last updated' : 'Última actualización'} · {updated}</span>
        </header>

        {isEnglish ? (
          <div class="legal-content">
            <section><h2>1. What this site stores</h2><p>This site uses browser storage and, only when you consent, services that may place cookies. Cookies are small text files; local storage is a similar browser mechanism that remains on your device. Non-essential services are disabled by default.</p></section>
            <section><h2>2. Necessary storage</h2><div class="legal-table" role="region" aria-label="Necessary storage" tabindex="0"><table><thead><tr><th>Name / owner</th><th>Purpose</th><th>Duration</th></tr></thead><tbody><tr><td><code>site-consent-v1</code><br />This website</td><td>Stores the chosen analytics and external-media categories, update date, and expiry date.</td><td>Maximum 24 months, or until removed or the consent version changes</td></tr></tbody></table></div><p>This local-storage entry is necessary to remember your request and prevent optional services from loading against your choice.</p></section>
            <section><h2>3. Analytics (optional)</h2><div class="legal-table" role="region" aria-label="Optional analytics storage" tabindex="0"><table><thead><tr><th>Name / owner</th><th>Purpose</th><th>Duration</th></tr></thead><tbody><tr><td><code>_ga</code><br />Google Analytics</td><td>Distinguishes browsers for audience and usage measurement.</td><td>2 years</td></tr><tr><td><code>_ga_&lt;measurement-id&gt;</code><br />Google Analytics</td><td>Persists session state for the configured GA4 property.</td><td>2 years</td></tr><tr><td>No cookie<br />Cloudflare Web Analytics</td><td>Measures aggregate traffic. The configured beacon is still held until analytics consent is given.</td><td>No browser cookie set by the standard Web Analytics beacon</td></tr></tbody></table></div><p>These services are not loaded before analytics consent. The list reflects the current configuration; enabling advertising integrations or another analytics feature requires this table and the consent mechanism to be reviewed.</p></section>
            <section><h2>4. External media (optional)</h2><div class="legal-table" role="region" aria-label="Optional external-media services" tabindex="0"><table><thead><tr><th>Provider</th><th>Purpose and possible storage</th><th>Provider information</th></tr></thead><tbody><tr><td>YouTube / Google</td><td>Loads video thumbnails and privacy-enhanced players. Google may use cookies or local storage for video delivery, preferences, security, and fraud prevention after the service is enabled.</td><td><a href="https://policies.google.com/technologies/cookies" target="_blank" rel="noreferrer">Google cookie information</a></td></tr><tr><td>Spotify</td><td>Loads audio previews and embedded players. Spotify may use cookies or local storage for playback, session, security, and service preferences.</td><td><a href="https://www.spotify.com/legal/cookies-policy/" target="_blank" rel="noreferrer">Spotify cookie policy</a></td></tr><tr><td>Apple Music</td><td>Loads audio previews and embedded players. Apple may use cookies or local storage for playback, locale, security, and service preferences.</td><td><a href="https://www.apple.com/legal/privacy/en-ww/cookies/" target="_blank" rel="noreferrer">Apple cookie information</a></td></tr></tbody></table></div><p>Without external-media consent, these frames, thumbnails, and audio files remain blocked. Third-party storage is controlled by each provider and can change; the linked provider information gives its current names and lifetimes.</p></section>
            <section><h2>5. Change or withdraw consent</h2><p>Use “Cookie settings” at the bottom of this page to accept, reject, or change categories. Withdrawing analytics consent removes recognisable first-party analytics cookies and reloads the page to stop already loaded analytics code. You can also clear site data in your browser.</p><p>See the <a href={privacyHref}>privacy policy</a> for information about controllers, providers, transfers, and your rights.</p></section>
          </div>
        ) : (
          <div class="legal-content">
            <section><h2>1. Qué almacena este sitio</h2><p>Este sitio utiliza almacenamiento del navegador y, solo cuando lo autorizas, servicios que pueden instalar cookies. Las cookies son pequeños archivos de texto; el almacenamiento local es un mecanismo similar que permanece en tu dispositivo. Los servicios opcionales están desactivados por defecto.</p></section>
            <section><h2>2. Almacenamiento necesario</h2><div class="legal-table" role="region" aria-label="Almacenamiento necesario" tabindex="0"><table><thead><tr><th>Nombre / titular</th><th>Finalidad</th><th>Duración</th></tr></thead><tbody><tr><td><code>site-consent-v1</code><br />Este sitio web</td><td>Guarda las categorías elegidas de analíticas y contenido externo, la fecha de actualización y la fecha de caducidad.</td><td>Máximo 24 meses, o hasta que se borre o cambie la versión del consentimiento</td></tr></tbody></table></div><p>Esta entrada de almacenamiento local es necesaria para recordar tu solicitud e impedir que los servicios opcionales se carguen en contra de tu elección.</p></section>
            <section><h2>3. Analíticas (opcionales)</h2><div class="legal-table" role="region" aria-label="Almacenamiento analítico opcional" tabindex="0"><table><thead><tr><th>Nombre / titular</th><th>Finalidad</th><th>Duración</th></tr></thead><tbody><tr><td><code>_ga</code><br />Google Analytics</td><td>Distingue navegadores para medir la audiencia y el uso.</td><td>2 años</td></tr><tr><td><code>_ga_&lt;measurement-id&gt;</code><br />Google Analytics</td><td>Mantiene el estado de la sesión para la propiedad GA4 configurada.</td><td>2 años</td></tr><tr><td>Sin cookie<br />Cloudflare Web Analytics</td><td>Mide tráfico agregado. Aun así, la baliza configurada no se carga hasta obtener consentimiento analítico.</td><td>La baliza Web Analytics estándar no crea una cookie en el navegador</td></tr></tbody></table></div><p>Estos servicios no se cargan antes del consentimiento analítico. La lista refleja la configuración actual; activar publicidad integrada u otra función analítica exige revisar esta tabla y el mecanismo de consentimiento.</p></section>
            <section><h2>4. Contenido externo (opcional)</h2><div class="legal-table" role="region" aria-label="Servicios opcionales de contenido externo" tabindex="0"><table><thead><tr><th>Proveedor</th><th>Finalidad y posible almacenamiento</th><th>Información del proveedor</th></tr></thead><tbody><tr><td>YouTube / Google</td><td>Carga miniaturas y reproductores en modo de privacidad mejorada. Google puede usar cookies o almacenamiento local para entregar el vídeo, guardar preferencias, aportar seguridad y prevenir fraude tras habilitar el servicio.</td><td><a href="https://policies.google.com/technologies/cookies" target="_blank" rel="noreferrer">Información de cookies de Google</a></td></tr><tr><td>Spotify</td><td>Carga fragmentos de audio y reproductores integrados. Spotify puede usar cookies o almacenamiento local para reproducción, sesión, seguridad y preferencias del servicio.</td><td><a href="https://www.spotify.com/legal/cookies-policy/" target="_blank" rel="noreferrer">Política de cookies de Spotify</a></td></tr><tr><td>Apple Music</td><td>Carga fragmentos de audio y reproductores integrados. Apple puede usar cookies o almacenamiento local para reproducción, idioma o región, seguridad y preferencias del servicio.</td><td><a href="https://www.apple.com/legal/privacy/en-ww/cookies/" target="_blank" rel="noreferrer">Información de cookies de Apple</a></td></tr></tbody></table></div><p>Sin consentimiento para contenido externo, esos marcos, miniaturas y archivos de audio permanecen bloqueados. El almacenamiento de terceros está bajo el control de cada proveedor y puede cambiar; los enlaces anteriores recogen sus nombres y duraciones vigentes.</p></section>
            <section><h2>5. Cambiar o retirar el consentimiento</h2><p>Utiliza «Ajustes de cookies» al final de esta página para aceptar, rechazar o cambiar las categorías. Al retirar las analíticas eliminamos las cookies propias de analítica reconocibles y recargamos la página para detener el código ya cargado. También puedes borrar los datos del sitio desde tu navegador.</p><p>Consulta la <a href={privacyHref}>política de privacidad</a> para conocer los responsables, proveedores, transferencias y tus derechos.</p></section>
          </div>
        )}
      </article>
    )}

    <footer class="legal-footer">
      <a href={privacyHref}>{isEnglish ? 'Privacy policy' : 'Política de privacidad'}</a>
      <a href={cookieHref}>{isEnglish ? 'Cookie policy' : 'Política de cookies'}</a>
      <button type="button" data-legal-consent>{isEnglish ? 'Cookie settings' : 'Ajustes de cookies'}</button>
      <span>© {new Date().getFullYear()} {site.fullName}</span>
    </footer>
  </main>
</Base>

<style>
  .legal-page { min-height: 100dvh; padding: clamp(7rem, 12vw, 9rem) clamp(1.25rem, 7vw, 8rem) 4rem; background: radial-gradient(circle at 90% 5%, rgba(198,146,62,.12), transparent 25rem), var(--stage); }
  .legal-back { display: inline-block; color: var(--ink-muted); font: .68rem var(--font-mono); letter-spacing: .08em; text-decoration: none; text-transform: uppercase; }
  .legal-back:hover { color: var(--accent); }
  article { width: min(100%, 72rem); margin: clamp(3rem, 8vw, 7rem) auto 0; }
  .legal-hero { display: grid; grid-template-columns: minmax(0,1fr) auto; gap: 1.5rem; align-items: end; padding-bottom: clamp(2rem, 5vw, 4rem); border-bottom: 1px solid color-mix(in srgb, var(--ink) 16%, transparent); }
  .legal-hero p { grid-column: 1 / -1; margin: 0; color: var(--accent); font: .68rem var(--font-mono); letter-spacing: .12em; text-transform: uppercase; }
  .legal-hero h1 { margin: 0; font-family: var(--font-display); font-size: clamp(3.2rem, 8vw, 7rem); font-weight: 320; letter-spacing: -.04em; line-height: .88; }
  .legal-hero span { color: var(--ink-muted); font: .64rem var(--font-mono); letter-spacing: .06em; text-transform: uppercase; white-space: nowrap; }
  .legal-content { margin: 0 0 0 auto; width: min(100%, 49rem); }
  .legal-content section { padding: clamp(2.2rem, 5vw, 4rem) 0; border-bottom: 1px solid color-mix(in srgb, var(--ink) 12%, transparent); }
  .legal-content h2 { margin: 0 0 1.2rem; font-family: var(--font-display); font-size: clamp(1.7rem, 3vw, 2.35rem); font-weight: 400; line-height: 1.1; }
  .legal-content p { margin: .9rem 0 0; color: var(--ink-muted); font-size: clamp(.95rem, 1.4vw, 1.05rem); line-height: 1.8; }
  .legal-content strong { color: var(--ink); }
  .legal-content a, .legal-footer a, .legal-footer button { color: var(--ink); text-underline-offset: .25rem; }
  .legal-content a:hover, .legal-footer a:hover, .legal-footer button:hover { color: var(--accent); }
  code { padding: .15em .35em; border: 1px solid color-mix(in srgb, var(--ink) 13%, transparent); border-radius: .25rem; color: var(--accent); font: .82em var(--font-mono); }
  .legal-table { margin-top: 1.5rem; overflow-x: auto; }
  table { width: 100%; min-width: 38rem; border-collapse: collapse; color: var(--ink-muted); font-size: .85rem; line-height: 1.5; }
  th, td { padding: .9rem 1rem; border: 1px solid color-mix(in srgb, var(--ink) 13%, transparent); text-align: left; vertical-align: top; }
  th { color: var(--ink); font: .62rem var(--font-mono); letter-spacing: .08em; text-transform: uppercase; }
  .legal-footer { display: flex; flex-wrap: wrap; gap: 1rem 2rem; width: min(100%, 72rem); margin: 4rem auto 0; padding-top: 2rem; border-top: 1px solid color-mix(in srgb, var(--ink) 16%, transparent); color: var(--ink-muted); font-size: .75rem; }
  .legal-footer button { padding: 0; border: 0; background: transparent; cursor: pointer; font: inherit; text-decoration: underline; }
  .legal-footer span { margin-left: auto; }
  @media (max-width: 640px) { .legal-hero { grid-template-columns: 1fr; } .legal-hero p { grid-column: auto; } .legal-footer span { width: 100%; margin-left: 0; } }
</style>

<script>
  import { requestConsent } from '@/lib/consent';

  const initLegalConsent = () => {
    document.querySelectorAll<HTMLButtonElement>('[data-legal-consent]:not([data-ready])').forEach((button) => {
      button.dataset.ready = 'true';
      button.addEventListener('click', () => requestConsent());
    });
  };

  initLegalConsent();
  document.addEventListener('astro:page-load', initLegalConsent);
</script>
