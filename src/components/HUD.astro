---
import { site } from '@/data/site';
import type { Locale } from '@/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const stations = site.stations.filter((station) => station.kind !== 'hero');
---
<div
  class="pointer-events-none absolute bottom-4 left-4 right-4 z-40 flex flex-col gap-3 text-ink md:bottom-6 md:left-6 md:right-6"
  data-hud
>
  <div class="flex items-end justify-between gap-4">
    <div class="hud-station mix-blend-difference" aria-live="polite">
      <span class="hud-station__kicker" data-hud-index>01</span>
      <span class="hud-station__name" data-hud-station>{stations[0]?.heading[locale]}</span>
    </div>
    <div class="hud-progress mix-blend-difference" aria-hidden="true">
      <div
        class="hud-progress__bar"
        style="transform: scaleX(0);"
        data-hud-progress
      ></div>
    </div>
  </div>

  <nav class="hud-nav pointer-events-auto" aria-label={locale === 'en' ? 'Stage stations' : 'Estaciones'}>
    {stations.map((station, index) => (
      <a
        href={`#${station.id}`}
        class="hud-nav__link"
        data-hud-station-link={station.id}
        aria-label={`${String(index + 1).padStart(2, '0')} ${station.heading[locale]}`}
      >
        <span class="hud-nav__number" aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
        <span class="hud-nav__label">{station.heading[locale]}</span>
      </a>
    ))}
  </nav>
</div>
