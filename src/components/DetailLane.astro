---
import LaneArrow from '@/components/LaneArrow.astro';
import MobilePlaybackControl from '@/components/MobilePlaybackControl.astro';
import type { Locale } from '@/i18n';
interface Props { id: string; title: string; locale: Locale; }
const { id, title, locale } = Astro.props;
const back = locale === 'en' ? 'Back to main lane' : 'Volver a la línea principal';
const backCta = locale === 'en' ? 'Back' : 'Volver';
const next = locale === 'en' ? 'Continue to the next section' : 'Continuar a la siguiente sección';
const nextCta = locale === 'en' ? 'Next' : 'Siguiente';
---
<section
  class="detail-lane"
  data-detail-lane={id}
  data-lenis-prevent
  aria-label={title}
  aria-hidden="true"
  inert
  hidden
>
  <div class="detail-lane__scroll" data-detail-scroll tabindex="-1">
    <header class="detail-lane__header">
      <LaneArrow direction="up" label={back} cta={backCta} />
      <MobilePlaybackControl locale={locale} />
    </header>
    <div class="detail-lane__body">
      <slot />
    </div>
    <footer class="detail-lane__footer">
      <LaneArrow direction="down" next label={next} cta={nextCta} withString />
    </footer>
  </div>
</section>

<style>
  .detail-lane {
    position: fixed; inset: 0; z-index: 60;
    background: var(--color-stage); color: var(--color-ink);
  }
  .detail-lane[hidden] { display: none; }
  /* Motion lanes remain laid out while closed so their fixed geometry is ready
     before the compositor transition. `hidden`, `inert` and `aria-hidden` keep
     them out of interaction and the accessibility tree. */
  @media (prefers-reduced-motion: no-preference) {
    .detail-lane[hidden] {
      display: block;
      pointer-events: none;
    }
  }
  .detail-lane__scroll {
    height: 100dvh; overflow-y: auto; overflow-x: hidden;
    overscroll-behavior: contain; -webkit-overflow-scrolling: touch;
    /* Hide the native scrollbar to match the showcase (which also hides it) — it
       otherwise renders a stray gutter/overlap over the content here. Scrolling
       is via wheel/gesture; the header + footer chevrons mark the two ends. */
    scrollbar-width: none;
  }
  .detail-lane__scroll::-webkit-scrollbar { display: none; }
  .detail-lane__scroll:focus { outline: none; }
  .detail-lane__header {
    display: flex; flex-direction: column; align-items: center; gap: 1rem;
    padding-top: clamp(2rem, 6vh, 5rem);
  }
  .detail-lane__footer {
    display: flex; justify-content: center;
    padding: clamp(1rem, 3vh, 2.5rem) 1rem clamp(2.5rem, 7vh, 6rem);
  }
  .detail-lane__body { padding: clamp(2rem, 6vh, 6rem) var(--detail-lane-edge) 4vh; }
  /* Reduced-motion: lanes are inline in the vertical stack, not a fixed slide
     layer. Mobile (with motion) keeps the fixed layer — Task 4 slides it in
     from the right. */
  @media (prefers-reduced-motion: reduce) {
    .detail-lane { position: relative; inset: auto; z-index: auto; }
    .detail-lane__scroll { height: auto; overflow: visible; }
  }
  /* Mobile: the desktop clamp()s above assume the slotted content (VideoGallery,
     AlbumStoryPlayer, ClassesContent) contributes its own top/side padding on
     top of this — on mobile those components no longer add their own, so this
     is now the ONLY padding source and needs to be much tighter, not the same
     generous desktop clamp. */
  @media (max-width: 767px) {
    .detail-lane__header {
      position: sticky;
      top: 0;
      z-index: 5;
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      min-height: calc(4.25rem + env(safe-area-inset-top));
      padding: env(safe-area-inset-top) var(--detail-lane-edge) 0;
      border-bottom: 1px solid color-mix(in srgb, var(--color-ink) 9%, transparent);
      background: color-mix(in srgb, var(--color-stage) 90%, transparent);
      backdrop-filter: blur(16px) saturate(120%);
      -webkit-backdrop-filter: blur(16px) saturate(120%);
    }

    .detail-lane__header :global(.lane-arrow) {
      flex-direction: row;
      gap: 0.4rem;
      min-height: 2.75rem;
      padding: 0;
    }

    .detail-lane__header :global(.lane-arrow__chevrons) {
      flex-direction: row;
    }

    .detail-lane__header :global(.lane-arrow__label) {
      letter-spacing: 0.16em;
      opacity: 0.8;
    }

    .detail-lane__body {
      padding-top: 0.5rem;
      padding-bottom: 1rem;
    }

    .detail-lane__footer {
      padding: 0.5rem var(--detail-lane-edge) max(1.25rem, env(safe-area-inset-bottom));
    }

    .detail-lane__footer :global(.lane-arrow) {
      gap: 0.3rem;
      padding: 0.5rem;
    }

    .detail-lane__footer :global(.lane-arrow__string) {
      width: min(12rem, 58vw);
      height: 1rem;
    }

    .detail-lane__footer :global(.lane-arrow .arrow) {
      width: 2.25rem;
      height: 2.25rem;
    }
  }
</style>
