---
import type { Station } from '@/data/site';
import type { Locale } from '@/i18n';
import { site } from '@/data/site';
import LaneArrow from '@/components/LaneArrow.astro';

interface Props { station: Station; locale: Locale; }
const { station, locale } = Astro.props;
const isHero = station.kind === 'hero';
const order = ['about', 'music', 'videos', 'guitar', 'classes'];
const num = order.indexOf(station.id) + 1;
const artifact = { about:'score', music:'wave', videos:'frame', guitar:'rosette', classes:'signal' }[station.id] ?? 'score';
const openLabel = locale === 'en' ? `Open ${station.heading.en} details` : `Abrir ${station.heading.es}`;
---
{isHero ? (
  <div class="relative w-full h-full flex items-center justify-center px-6 text-center overflow-hidden" data-hero-stage data-station-title={station.heading[locale]}>
    <div class="absolute inset-0 -z-10 pointer-events-none" data-hero-spotlight aria-hidden="true"></div>
    <div class="hero-stage__strings" data-parallax-x="-0.22" aria-hidden="true">
      {Array.from({ length: 6 }).map(() => <span></span>)}
    </div>
    <div class="hero-stage__wash" data-parallax-x="0.10" aria-hidden="true"></div>
    <div class="relative z-10 flex flex-col items-center gap-4 md:gap-6" data-parallax-x="0.05">
      <h1 class="station-hero__title font-display font-light tracking-tight text-ink">{site.fullName}</h1>
      {station.tagline && <p class="font-sans text-lg md:text-2xl text-ink-muted">{station.tagline[locale]}</p>}
    </div>
  </div>
) : (
  <div class="station group relative flex w-full flex-col justify-center gap-6 text-ink" data-station-title={station.heading[locale]} data-station-kind={station.id}>
    <div class="station__wash" data-parallax-x="-0.16" aria-hidden="true"></div>
    <div class:list={['station__artifact', `station__artifact--${artifact}`]} data-parallax-x="0.28" aria-hidden="true">
      <div class="station__artifact-lean" data-parallax-lean>
        {Array.from({ length: 4 }).map(() => <span></span>)}
      </div>
    </div>
    <div class="station__copy" data-parallax-x="-0.06">
      <span data-reveal="heading" data-text-reveal-preset="label" class="station__number">{String(Math.max(num,1)).padStart(2,'0')}</span>
      <h2 data-reveal="heading" data-text-reveal-preset="headline" data-parallax-lean class="station__heading font-display font-light tracking-tight">{station.heading[locale]}</h2>
      {station.tagline && <p data-reveal="body" class="font-sans text-lg md:text-xl text-ink-muted max-w-prose">{station.tagline[locale]}</p>}
    </div>
    {station.detail && (
      <div data-reveal="cta" class="station__enter">
        <LaneArrow direction="down" targetId={station.id} label={openLabel} withString />
      </div>
    )}
  </div>
)}

<style>
  .station-hero__title { font-size: clamp(3.5rem, 12vw, 9rem); }
  .station__heading { font-size: clamp(2.5rem, 9vw, 6.5rem); }
  .station__copy { position: relative; z-index: 2; max-width: 48rem; container-type: inline-size; display: flex; flex-direction: column; gap: 1.25rem; }
  .station__number { font-family: var(--font-mono, monospace); font-size: 0.8rem; letter-spacing: 0.2em; color: var(--color-accent); }
  .station__enter { margin-top: 1.5rem; }

  /* Ported from StationTeaser.astro's rendered classes / global.css
     (station-teaser__* -> station__*). hero-stage__* classes are left
     unrenamed above and keep using the existing global.css rules. */
  .station {
    min-height: min(42rem, 72dvh);
  }

  .station__wash {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(circle at 22% 36%, color-mix(in srgb, var(--accent) 25%, transparent), transparent 34%),
      linear-gradient(110deg, transparent 0%, color-mix(in srgb, var(--accent) 8%, transparent) 48%, transparent 78%);
    opacity: 0.88;
  }

  .station__artifact {
    position: absolute;
    right: clamp(1rem, 8vw, 8rem);
    top: 50%;
    z-index: 1;
    width: clamp(8rem, 22vw, 20rem);
    aspect-ratio: 1;
    opacity: 0.56;
    transform: translateY(-50%);
  }

  /* `.station__artifact` already carries the GSAP `data-parallax-x` scrub,
     which writes its own inline `transform` every tick — an inline style
     would silently clobber the `[data-parallax-lean]` CSS-var-based
     translateX rule if applied to the same element. So the velocity lean
     lives on this inner wrapper instead: `inset: 0` inside the (already
     positioned) `.station__artifact` reproduces the exact same box, so the
     artifact's absolutely-positioned spans are unaffected. */
  .station__artifact-lean {
    position: absolute;
    inset: 0;
  }

  .station__artifact span {
    position: absolute;
    display: block;
    border-color: color-mix(in srgb, var(--accent) 74%, transparent);
  }

  .station__artifact--score span {
    left: 8%;
    right: 8%;
    height: 1px;
    background: color-mix(in srgb, var(--accent) 64%, transparent);
  }

  .station__artifact--score span:nth-child(1) { top: 30%; }
  .station__artifact--score span:nth-child(2) { top: 40%; }
  .station__artifact--score span:nth-child(3) { top: 50%; }
  .station__artifact--score span:nth-child(4) { top: 60%; }

  .station__artifact--wave span {
    bottom: 18%;
    width: 10%;
    background: color-mix(in srgb, var(--accent) 76%, transparent);
  }

  .station__artifact--wave span:nth-child(1) { left: 18%; height: 36%; }
  .station__artifact--wave span:nth-child(2) { left: 36%; height: 66%; }
  .station__artifact--wave span:nth-child(3) { left: 54%; height: 48%; }
  .station__artifact--wave span:nth-child(4) { left: 72%; height: 78%; }

  .station__artifact--frame {
    border: 1px solid color-mix(in srgb, var(--accent) 52%, transparent);
    aspect-ratio: 16 / 10;
  }

  .station__artifact--frame span {
    inset: 18% 12%;
    border-top: 1px solid;
    border-bottom: 1px solid;
  }

  .station__artifact--rosette {
    border: 1px solid color-mix(in srgb, var(--accent) 46%, transparent);
    border-radius: 9999px;
  }

  .station__artifact--rosette span {
    inset: calc(var(--i, 1) * 10%);
    border: 1px solid;
    border-radius: 9999px;
  }

  .station__artifact--rosette span:nth-child(1) { --i: 1; }
  .station__artifact--rosette span:nth-child(2) { --i: 2; }
  .station__artifact--rosette span:nth-child(3) { --i: 3; }
  .station__artifact--rosette span:nth-child(4) { --i: 4; }

  .station__artifact--fretboard span {
    top: 8%;
    bottom: 8%;
    width: 1px;
    background: color-mix(in srgb, var(--accent) 64%, transparent);
  }

  .station__artifact--fretboard span:nth-child(1) { left: 20%; }
  .station__artifact--fretboard span:nth-child(2) { left: 40%; }
  .station__artifact--fretboard span:nth-child(3) { left: 62%; }
  .station__artifact--fretboard span:nth-child(4) { left: 84%; }

  .station__artifact--signal span {
    left: 50%;
    top: 50%;
    border: 1px solid;
    border-radius: 9999px;
    transform: translate(-50%, -50%);
  }

  .station__artifact--signal span:nth-child(1) { width: 18%; height: 18%; }
  .station__artifact--signal span:nth-child(2) { width: 38%; height: 38%; }
  .station__artifact--signal span:nth-child(3) { width: 62%; height: 62%; }
  .station__artifact--signal span:nth-child(4) { width: 88%; height: 88%; }

  @media (max-width: 767px) {
    .station {
      min-height: 100dvh;
      padding: 0 1.5rem;
    }

    .station__artifact {
      right: 1.5rem;
      top: 32%;
      width: min(42vw, 11rem);
      opacity: 0.32;
    }

    .station__copy {
      max-width: 24rem;
    }
  }
</style>
