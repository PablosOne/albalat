---
import type { Locale } from '@/i18n';
import { useTranslations } from '@/i18n';
import { site } from '@/data/site';
import LangToggle from './LangToggle.astro';
import Wordmark from './Wordmark.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const pathname = Astro.url.pathname;
const isHome = pathname === '/' || pathname === '/en/';
const toolbarAttrs = isHome
  ? { 'data-toolbar': true, style: 'opacity: 0; clip-path: inset(0% 0% 100% 0%)' }
  : {};

function localizePath(path: string): string {
  if (locale === 'es') return path;
  return path === '/' ? '/en/' : `/en${path}`;
}

const navItems = ['about', 'music', 'videos', 'classes', 'contact'].map((id, index) => ({
    id,
    label: t(`nav.${id}`),
    href: `${isHome ? '' : localizePath('/')}#${id}`,
    number: String(index + 1).padStart(2, '0'),
  }));

const homeHref = localizePath('/');
---
<a
  href="#main-content"
  class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[70] focus:rounded-full focus:bg-ink focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-stage"
>
  {t('a11y.skipToContent')}
</a>

<Wordmark />

<nav
  {...toolbarAttrs}
  class="nav-bar fixed inset-x-0 top-0 z-50"
  aria-label={t('nav.home')}
  data-mobile-nav
>
  <div class="nav-mobile-bar">
    <a href={homeHref} class="nav-mobile-brand" aria-label={t('nav.home')}>
      <span>{site.fullName}</span>
      <span class="nav-mobile-brand__dot" aria-hidden="true"></span>
    </a>
    <button
      type="button"
      class="nav-trigger"
      aria-expanded="false"
      aria-controls="mobile-navigation-drawer"
      aria-label={t('a11y.openMenu')}
      data-nav-trigger
      data-open-label={t('a11y.openMenu')}
      data-close-label={t('a11y.closeMenu')}
    >
      <span class="nav-trigger__icon" aria-hidden="true">
        <span></span><span></span>
      </span>
    </button>
  </div>

  <button class="nav-scrim" type="button" tabindex="-1" aria-label={t('a11y.closeMenu')} data-nav-scrim></button>

  <div class="nav-drawer" id="mobile-navigation-drawer" data-nav-drawer>
    <div class="nav-drawer__ornament" aria-hidden="true">
      {[0, 1, 2, 3, 4, 5].map(() => <span></span>)}
    </div>

    <div class="nav-drawer__head">
      <span>{locale === 'en' ? 'Navigation' : 'Navegación'}</span>
      <span>{locale.toUpperCase()}</span>
    </div>

    <ul class="nav-bar__list">
      <li class="nav-item nav-item--home" style="--nav-i: 0">
        <a href={homeHref} aria-current={pathname === homeHref ? 'page' : undefined}>
          <span class="nav-item__number">00</span>
          <span>{t('nav.home')}</span>
          <svg class="nav-item__arrow" viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h13M13 6l6 6-6 6"></path></svg>
        </a>
      </li>
      {navItems.map((item, index) => (
        <li class="nav-item" style={`--nav-i: ${index + 1}`}>
          <a href={item.href}>
            <span class="nav-item__number">{item.number}</span>
            <span>{item.label}</span>
            <svg class="nav-item__arrow" viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h13M13 6l6 6-6 6"></path></svg>
          </a>
        </li>
      ))}
      <li class="nav-language" style={`--nav-i: ${navItems.length + 1}`}>
        <span>{locale === 'en' ? 'Language' : 'Idioma'}</span>
        <LangToggle locale={locale} />
      </li>
    </ul>

    <p class="nav-drawer__footer">{locale === 'en' ? 'Classical guitarist' : 'Guitarrista clásico'} · Madrid</p>
  </div>
</nav>

<style>
  .nav-mobile-bar,
  .nav-scrim,
  .nav-drawer__head,
  .nav-drawer__ornament,
  .nav-drawer__footer,
  .nav-item__number,
  .nav-item__arrow,
  .nav-language > span {
    display: none;
  }

  .nav-bar__list {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 1.5rem;
    font-family: var(--font-mono);
    font-size: var(--fs-label);
    letter-spacing: 0.04em;
    line-height: 1.55;
    text-transform: uppercase;
  }

  .nav-item a {
    color: var(--color-fg);
    text-decoration: none;
    white-space: nowrap;
  }

  .nav-item a:hover,
  .nav-item a:focus-visible {
    color: var(--color-accent);
    outline: none;
    text-decoration: underline;
    text-underline-offset: 0.25rem;
  }

  @media (max-width: 1279px) {
    .nav-bar {
      height: 4.5rem;
      pointer-events: none;
      color: #f4efe7;
      transition: opacity 260ms ease, transform 360ms cubic-bezier(.22,1,.36,1);
    }

    .nav-mobile-bar {
      position: relative;
      z-index: 3;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      width: 3.5rem;
      height: 3.5rem;
      margin: max(0.55rem, env(safe-area-inset-top)) 0.55rem 0 auto;
      padding: 0.1rem;
      border: 1px solid rgba(244, 239, 231, 0.12);
      border-radius: 999px;
      background: rgba(11, 10, 9, 0.76);
      box-shadow: 0 0.75rem 2.5rem rgba(0, 0, 0, 0.22);
      backdrop-filter: blur(18px) saturate(125%);
      -webkit-backdrop-filter: blur(18px) saturate(125%);
      pointer-events: auto;
      overflow: hidden;
      transition: width 520ms cubic-bezier(.76,0,.24,1), height 420ms cubic-bezier(.76,0,.24,1), padding 420ms ease, background-color 300ms ease, border-color 300ms ease;
    }

    .nav-mobile-brand {
      display: inline-flex;
      align-items: center;
      gap: 0.65rem;
      color: currentColor;
      font-family: var(--font-mono);
      font-size: 0.68rem;
      letter-spacing: 0.08em;
      text-decoration: none;
      text-transform: uppercase;
      max-width: 0;
      opacity: 0;
      overflow: hidden;
      transform: translateX(1rem);
      white-space: nowrap;
      transition: max-width 480ms cubic-bezier(.22,1,.36,1), opacity 240ms ease, transform 480ms cubic-bezier(.22,1,.36,1);
    }

    .nav-mobile-brand__dot {
      width: 0.35rem;
      height: 0.35rem;
      border-radius: 50%;
      background: var(--color-accent);
      box-shadow: 0 0 0 0 rgba(198, 146, 62, 0.45);
      animation: nav-dot-pulse 2.4s ease-out infinite;
    }

    .nav-trigger {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0;
      min-width: 3.25rem;
      width: 3.25rem;
      min-height: 3.25rem;
      padding: 0;
      border: 1px solid rgba(244, 239, 231, 0.16);
      border-radius: 999px;
      background: rgba(244, 239, 231, 0.07);
      color: currentColor;
      cursor: pointer;
    }

    .nav-trigger__icon {
      position: relative;
      display: block;
      width: 1.15rem;
      height: 0.85rem;
    }

    .nav-trigger__icon span {
      position: absolute;
      right: 0;
      width: 100%;
      height: 1px;
      background: currentColor;
      transform-origin: center;
      transition: top 300ms cubic-bezier(.22,1,.36,1), transform 300ms cubic-bezier(.22,1,.36,1), width 300ms ease;
    }

    .nav-trigger__icon span:first-child { top: 0.2rem; }
    .nav-trigger__icon span:last-child { top: 0.65rem; width: 70%; }

    .nav-scrim {
      position: fixed;
      inset: 0;
      z-index: 1;
      display: block;
      border: 0;
      background: rgba(0, 0, 0, 0.62);
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      backdrop-filter: blur(5px);
      -webkit-backdrop-filter: blur(5px);
      transition: opacity 380ms ease, visibility 380ms;
    }

    .nav-drawer {
      position: fixed;
      inset: 0 0 0 auto;
      z-index: 2;
      display: flex;
      flex-direction: column;
      width: min(89vw, 25rem);
      height: 100dvh;
      overflow: hidden;
      padding: calc(6.4rem + env(safe-area-inset-top)) 1.5rem max(1.5rem, env(safe-area-inset-bottom));
      border-left: 1px solid rgba(244, 239, 231, 0.12);
      background:
        radial-gradient(circle at 90% 15%, rgba(198, 146, 62, 0.14), transparent 28%),
        #0b0a09;
      box-shadow: -1rem 0 4rem rgba(0, 0, 0, 0.35);
      pointer-events: none;
      transform: translate3d(104%, 0, 0);
      visibility: hidden;
      transition: transform 560ms cubic-bezier(.76,0,.24,1), visibility 560ms;
    }

    .nav-drawer__head {
      position: relative;
      z-index: 1;
      display: flex;
      justify-content: space-between;
      padding-bottom: 0.85rem;
      border-bottom: 1px solid rgba(244, 239, 231, 0.14);
      color: rgba(244, 239, 231, 0.46);
      font-family: var(--font-mono);
      font-size: 0.6rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .nav-drawer__ornament {
      position: absolute;
      inset: 18% -26% auto -18%;
      display: grid;
      gap: clamp(0.85rem, 3vw, 1.3rem);
      opacity: 0.34;
      pointer-events: none;
      transform: rotate(-7deg) translateX(8%);
      transition: transform 900ms cubic-bezier(.22,1,.36,1), opacity 600ms ease;
    }

    .nav-drawer__ornament span {
      display: block;
      height: 1px;
      background: linear-gradient(90deg, transparent, color-mix(in srgb, var(--color-accent) 72%, transparent), transparent);
      box-shadow: 0 0 18px color-mix(in srgb, var(--color-accent) 42%, transparent);
    }

    .nav-bar__list {
      position: relative;
      z-index: 1;
      display: block;
      margin: auto 0;
    }

    .nav-item,
    .nav-language {
      opacity: 0;
      transform: translateX(2rem);
      transition: opacity 300ms ease, transform 420ms cubic-bezier(.22,1,.36,1);
      transition-delay: 0ms;
    }

    .nav-item a {
      display: grid;
      grid-template-columns: 2rem minmax(0, 1fr) 1.5rem;
      align-items: center;
      min-height: clamp(3.5rem, 8.5dvh, 4.6rem);
      border-bottom: 1px solid rgba(244, 239, 231, 0.1);
      color: #f4efe7;
      font-family: var(--font-display);
      font-size: clamp(1.65rem, 7.2vw, 2.25rem);
      font-weight: 400;
      letter-spacing: -0.025em;
      line-height: 0.95;
      text-transform: none;
    }

    .nav-item__number,
    .nav-item__arrow {
      display: block;
    }

    .nav-item__number {
      align-self: start;
      padding-top: 0.5rem;
      color: var(--color-accent);
      font-family: var(--font-mono);
      font-size: 0.52rem;
      letter-spacing: 0.08em;
    }

    .nav-item__arrow {
      width: 1.2rem;
      fill: none;
      stroke: currentColor;
      stroke-linecap: round;
      stroke-linejoin: round;
      stroke-width: 1.25;
      opacity: 0.45;
      transition: opacity 180ms ease, transform 180ms ease;
    }

    .nav-item a:hover,
    .nav-item a:focus-visible {
      color: var(--color-accent);
      text-decoration: none;
    }

    .nav-item a:hover .nav-item__arrow,
    .nav-item a:focus-visible .nav-item__arrow {
      opacity: 1;
      transform: translateX(0.25rem);
    }

    .nav-language {
      display: flex;
      align-items: center;
      justify-content: space-between;
      min-height: 4.3rem;
      border-bottom: 1px solid rgba(244, 239, 231, 0.1);
    }

    .nav-language > span {
      display: inline;
      color: rgba(244, 239, 231, 0.48);
      font-family: var(--font-mono);
      font-size: 0.6rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .nav-drawer__footer {
      position: relative;
      z-index: 1;
      display: block;
      margin-top: 1rem;
      color: rgba(244, 239, 231, 0.38);
      font-family: var(--font-mono);
      font-size: 0.58rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .nav-bar[data-open] {
      pointer-events: auto;
    }

    .nav-bar[data-scrolled] .nav-mobile-bar,
    .nav-bar[data-open] .nav-mobile-bar {
      justify-content: space-between;
      width: calc(100% - 1.5rem);
      height: 4.5rem;
      margin-right: 0.75rem;
      padding: 0 0.65rem 0 1rem;
    }

    .nav-bar[data-scrolled] .nav-mobile-brand,
    .nav-bar[data-open] .nav-mobile-brand {
      max-width: 12rem;
      opacity: 1;
      transform: translateX(0);
    }

    .nav-bar[data-open] .nav-mobile-bar {
      border-color: rgba(198, 146, 62, 0.26);
      background: rgba(11, 10, 9, 0.94);
    }

    .nav-bar[data-open] .nav-trigger__icon span:first-child {
      top: 0.43rem;
      transform: rotate(45deg);
    }

    .nav-bar[data-open] .nav-trigger__icon span:last-child {
      top: 0.43rem;
      width: 100%;
      transform: rotate(-45deg);
    }

    .nav-bar[data-open] .nav-scrim {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
    }

    .nav-bar[data-open] .nav-drawer {
      pointer-events: auto;
      transform: translate3d(0, 0, 0);
      visibility: visible;
    }

    .nav-bar[data-open] .nav-drawer__ornament {
      opacity: 0.48;
      transform: rotate(-4deg) translateX(0);
    }

    .nav-bar[data-open] .nav-item,
    .nav-bar[data-open] .nav-language {
      opacity: 1;
      transform: translateX(0);
      transition-delay: calc(170ms + var(--nav-i) * 45ms);
    }

    @keyframes nav-dot-pulse {
      0% { box-shadow: 0 0 0 0 rgba(198, 146, 62, 0.42); }
      65%, 100% { box-shadow: 0 0 0 0.48rem rgba(198, 146, 62, 0); }
    }
  }

  @media (min-width: 1280px) {
    .nav-bar {
      inset: 1.5rem 1.5rem auto auto;
      mix-blend-mode: difference;
    }
  }

  @media (max-width: 370px), (max-height: 690px) and (max-width: 1279px) {
    .nav-drawer { padding-top: calc(5.7rem + env(safe-area-inset-top)); }
    .nav-item a { min-height: 3.2rem; font-size: 1.5rem; }
    .nav-language { min-height: 3.5rem; }
    .nav-drawer__footer { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-mobile-brand__dot { animation: none; }
    .nav-drawer,
    .nav-scrim,
    .nav-item,
    .nav-language,
    .nav-trigger__icon span,
    .nav-drawer__ornament { transition-duration: 0.01ms !important; }
  }
</style>

<script>
  let mobileNavGlobalCleanup: (() => void) | undefined;

  const initMobileNav = () => {
    const nav = document.querySelector<HTMLElement>('[data-mobile-nav]');
    if (!nav || nav.dataset.ready === 'true') return;
    nav.dataset.ready = 'true';

    const trigger = nav.querySelector<HTMLButtonElement>('[data-nav-trigger]');
    const drawer = nav.querySelector<HTMLElement>('[data-nav-drawer]');
    const scrim = nav.querySelector<HTMLButtonElement>('[data-nav-scrim]');
    if (!trigger || !drawer || !scrim) return;

    let lastFocused: HTMLElement | null = null;
    const focusable = () => Array.from(drawer.querySelectorAll<HTMLElement>('a[href], button:not([disabled])'));

    const setOpen = (open: boolean, restoreFocus = true) => {
      if (open) lastFocused = document.activeElement instanceof HTMLElement ? document.activeElement : null;
      nav.toggleAttribute('data-open', open);
      trigger.setAttribute('aria-expanded', String(open));
      trigger.setAttribute('aria-label', open ? (trigger.dataset.closeLabel || '') : (trigger.dataset.openLabel || ''));
      document.documentElement.toggleAttribute('data-nav-open', open);

      if (open) {
        window.setTimeout(() => focusable()[0]?.focus(), 180);
      } else if (restoreFocus) {
        lastFocused?.focus();
      }
    };

    trigger.addEventListener('click', () => setOpen(!nav.hasAttribute('data-open')));
    scrim.addEventListener('click', () => setOpen(false));
    drawer.querySelectorAll<HTMLAnchorElement>('a[href]').forEach((link) => {
      link.addEventListener('click', () => setOpen(false, false));
      link.addEventListener('keydown', (event) => {
        if (event.key === 'Enter') setOpen(false, false);
      });
    });
    // Lane navigation also listens in capture phase and deliberately stops the
    // event after handling station hashes. Register this document-level closer
    // before lanes initializes so the drawer closes without cancelling the
    // station navigation itself.
    const onDocumentNavClick = (event: MouseEvent) => {
      const target = event.target as Element | null;
      if (target?.closest('[data-nav-drawer] a[href]') && nav.contains(target)) {
        setOpen(false, false);
      }
    };
    document.addEventListener('click', onDocumentNavClick, { capture: true });

    nav.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && nav.hasAttribute('data-open')) {
        event.preventDefault();
        setOpen(false);
        return;
      }
      if (event.key !== 'Tab' || !nav.hasAttribute('data-open')) return;
      const items = [trigger, ...focusable()];
      const first = items[0];
      const last = items[items.length - 1];
      if (event.shiftKey && document.activeElement === first) {
        event.preventDefault();
        last?.focus();
      } else if (!event.shiftKey && document.activeElement === last) {
        event.preventDefault();
        first?.focus();
      }
    });

    const desktopMq = window.matchMedia('(min-width: 1280px)');
    const onDesktopChange = (event: MediaQueryListEvent) => {
      if (event.matches) setOpen(false, false);
    };
    desktopMq.addEventListener('change', onDesktopChange);

    const syncScrolledState = () => nav.toggleAttribute('data-scrolled', window.scrollY > 48);
    syncScrolledState();
    window.addEventListener('scroll', syncScrolledState, { passive: true });

    mobileNavGlobalCleanup?.();
    mobileNavGlobalCleanup = () => {
      document.removeEventListener('click', onDocumentNavClick, { capture: true });
      desktopMq.removeEventListener('change', onDesktopChange);
      window.removeEventListener('scroll', syncScrolledState);
    };
  };

  initMobileNav();
  document.addEventListener('astro:page-load', initMobileNav);
</script>
