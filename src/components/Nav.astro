---
import type { Locale } from '@/i18n';
import { useTranslations } from '@/i18n';
import { site } from '@/data/site';
import LangToggle from './LangToggle.astro';
import Wordmark from './Wordmark.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const pathname = Astro.url.pathname;
const isHome = pathname === '/' || pathname === '/en/';
const toolbarAttrs = isHome
  ? { 'data-toolbar': true, style: 'opacity: 0; clip-path: inset(0% 0% 100% 0%)' }
  : {};

function localizePath(path: string): string {
  if (locale === 'es') return path;
  return path === '/' ? '/en/' : `/en${path}`;
}

const navItems = site.stations
  .filter((station) => station.kind !== 'hero')
  .map((station) => ({
    id: station.id,
    label: t(`nav.${station.id}`),
    href: `#${station.id}`,
  }));

const homeHref = localizePath('/');
---
<a
  href="#main-content"
  class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[70] focus:rounded-full focus:bg-ink focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-stage"
>
  {t('a11y.skipToContent')}
</a>

<Wordmark />

<nav
  {...toolbarAttrs}
  class="nav-bar fixed top-0 inset-x-0 md:top-6 md:inset-x-auto md:right-6 md:left-auto z-50 md:mix-blend-difference"
  aria-label={t('nav.home')}
>
  <ul class="nav-bar__list flex items-center justify-start md:justify-end gap-6 md:gap-6 text-label py-4 md:py-0 overflow-x-auto [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
    <li>
      <a
        href={homeHref}
        class:list={[
          'text-[var(--color-fg)] hover:underline underline-offset-4 decoration-1 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)] rounded-sm',
          pathname === homeHref ? 'text-[var(--color-accent)]' : '',
        ]}
        aria-current={pathname === homeHref ? 'page' : undefined}
      >
        {t('nav.home')}
      </a>
    </li>
    {navItems.map((item) => (
      <li>
        <a
          href={item.href}
          class="whitespace-nowrap text-[var(--color-fg)] hover:underline underline-offset-4 decoration-1 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)] rounded-sm"
        >
          {item.label}
        </a>
      </li>
    ))}
    <li class="shrink-0">
      <LangToggle locale={locale} />
    </li>
  </ul>
</nav>

<style>
  @media (max-width: 767px) {
    .nav-bar {
      background: rgba(11, 10, 9, 0.92);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      min-height: 3.5rem;
    }

    .nav-bar__list {
      width: 100%;
      min-height: 3.5rem;
      padding-left: 1rem;
      padding-right: 1rem;
    }

    .nav-bar__list li:first-child {
      display: none;
    }
  }
</style>
