---
import type { Locale } from '@/i18n';

interface Props {
  locale: Locale;
  intent: 'class' | 'concert' | 'contact';
}

const { locale, intent } = Astro.props;
const accessKey = import.meta.env.PUBLIC_WEB3FORMS_KEY;
const email = 'hello@eulogioalbalat.com';
const copy = {
  es: {
    name: 'Nombre',
    email: 'Email',
    message: 'Mensaje',
    inquiryType: 'Tipo de consulta',
    classOption: 'Clase privada',
    concertOption: 'Concierto',
    contactOption: 'Consulta general',
    submit: 'Enviar consulta',
    sending: 'Enviando...',
    success: 'Gracias. La consulta se ha enviado correctamente.',
    error: 'No se ha podido enviar el formulario. Puedes escribir directamente por email.',
    unavailable: 'El formulario se activara al configurar Web3Forms. Mientras tanto, puedes escribir directamente por email.',
    required: 'Completa los campos obligatorios antes de enviar.',
    class: 'Consulta sobre clases y conciertos',
    concert: 'Consulta sobre conciertos',
    contact: 'Consulta general',
  },
  en: {
    name: 'Name',
    email: 'Email',
    message: 'Message',
    inquiryType: 'Inquiry type',
    classOption: 'Private class',
    concertOption: 'Concert',
    contactOption: 'General inquiry',
    submit: 'Send inquiry',
    sending: 'Sending...',
    success: 'Thank you. Your inquiry has been sent.',
    error: 'The form could not be sent. You can write directly by email.',
    unavailable: 'The form will be active once Web3Forms is configured. In the meantime, you can write directly by email.',
    required: 'Please complete the required fields before sending.',
    class: 'Classes and concerts inquiry',
    concert: 'Concert inquiry',
    contact: 'General inquiry',
  },
}[locale];

const subject = copy[intent];
const showInquiryType = intent === 'class';
---
<form
  class="inquiry-form flex flex-col gap-5"
  action="https://api.web3forms.com/submit"
  method="POST"
  novalidate
  data-inquiry-form
  data-success={copy.success}
  data-error={copy.error}
  data-required={copy.required}
>
  <input type="hidden" name="access_key" value={accessKey ?? ''} />
  <input type="hidden" name="subject" value={`${subject} - Eulogio Albalat`} />
  {!showInquiryType && <input type="hidden" name="inquiry_type" value={copy[`${intent}Option` as 'concertOption' | 'contactOption']} />}
  <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" />

  <label class="inquiry-field">
    <span>{copy.name}</span>
    <input
      required
      name="name"
      autocomplete="name"
      placeholder={locale === 'es' ? 'Tu nombre' : 'Your name'}
    />
  </label>

  {showInquiryType && (
    <label class="inquiry-field">
      <span>{copy.inquiryType}</span>
      <select
        required
        name="inquiry_type"
      >
        <option value={copy.classOption}>{copy.classOption}</option>
        <option value={copy.concertOption}>{copy.concertOption}</option>
      </select>
    </label>
  )}

  <label class="inquiry-field">
    <span>{copy.email}</span>
    <input
      required
      type="email"
      name="email"
      autocomplete="email"
      placeholder="you@example.com"
    />
  </label>

  <label class="inquiry-field">
    <span>{copy.message}</span>
    <textarea
      required
      name="message"
      rows="4"
      placeholder={locale === 'es' ? 'Cuéntame brevemente el contexto.' : 'Briefly describe the context.'}
    ></textarea>
  </label>

  <div class="flex flex-wrap items-center gap-6 pt-2">
    <button
      type="submit"
      class="border border-ink px-6 py-3 text-xs font-semibold uppercase tracking-[0.18em] text-ink transition-colors duration-200 hover:bg-ink hover:text-stage focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent disabled:cursor-not-allowed disabled:opacity-40"
      disabled={!accessKey}
      data-submit-label={copy.submit}
      data-sending-label={copy.sending}
    >
      {copy.submit} ->
    </button>
    <a class="text-sm font-medium text-ink-muted underline-offset-4 hover:text-accent hover:underline" href={`mailto:${email}`}>
      {email}
    </a>
    <p class="min-h-6 text-sm text-ink-muted" data-form-status role="alert">
      {!accessKey ? copy.unavailable : ''}
    </p>
  </div>
</form>

<div class="inquiry-success hidden" data-form-success role="status">
  <p>{locale === 'es' ? 'Mensaje enviado.' : 'Message sent.'}</p>
  <span>{copy.success}</span>
</div>

<script is:inline>
  document.querySelectorAll('[data-inquiry-form]').forEach((form) => {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      const formEl = event.currentTarget;
      if (!(formEl instanceof HTMLFormElement)) return;

      const status = formEl.querySelector('[data-form-status]');
      const button = formEl.querySelector('button[type="submit"]');
      const success = formEl.nextElementSibling;
      if (!(button instanceof HTMLButtonElement)) return;

      if (!formEl.checkValidity()) {
        formEl.reportValidity();
        if (status) status.textContent = formEl.dataset.required || '';
        return;
      }

      const submitLabel = button.dataset.submitLabel || button.textContent || '';
      button.disabled = true;
      button.textContent = button.dataset.sendingLabel || submitLabel;

      try {
        const response = await fetch(formEl.action, {
          method: 'POST',
          body: new FormData(formEl),
          headers: { Accept: 'application/json' },
        });

        if (!response.ok) throw new Error('Form submission failed');

        const json = await response.json().catch(() => ({ success: true }));
        if (json && json.success === false) throw new Error('Form submission failed');

        formEl.classList.add('hidden');
        if (success instanceof HTMLElement && success.matches('[data-form-success]')) {
          success.classList.remove('hidden');
        }
        if (typeof window.gtag === 'function') {
          window.gtag('event', 'generate_lead', { inquiry_type: formEl.querySelector('[name="inquiry_type"]')?.value ?? '' });
        }
      } catch {
        if (status) status.textContent = formEl.dataset.error || '';
      } finally {
        button.disabled = false;
        button.textContent = submitLabel;
      }
    });
  });
</script>

<style>
  .inquiry-field {
    display: grid;
    gap: 0.45rem;
    color: var(--ink-muted);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .inquiry-field input,
  .inquiry-field select,
  .inquiry-field textarea {
    width: 100%;
    border: 0;
    border-bottom: 1px solid color-mix(in srgb, var(--ink) 18%, transparent);
    background: transparent;
    color: var(--ink);
    font: inherit;
    font-size: 1.08rem;
    font-weight: 400;
    letter-spacing: 0;
    line-height: 1.5;
    outline: none;
    padding: 0.45rem 0 0.7rem;
    text-transform: none;
    transition: border-color 180ms ease;
  }

  .inquiry-field textarea {
    resize: vertical;
  }

  .inquiry-field input::placeholder,
  .inquiry-field textarea::placeholder {
    color: color-mix(in srgb, var(--ink-muted) 42%, transparent);
  }

  .inquiry-field input:focus,
  .inquiry-field select:focus,
  .inquiry-field textarea:focus {
    border-color: var(--ink);
  }

  .inquiry-success p {
    color: var(--ink);
    font-family: var(--font-display);
    font-size: clamp(3.2rem, 8vw, 6.8rem);
    font-weight: 300;
    letter-spacing: 0;
    line-height: 0.95;
  }

  .inquiry-success span {
    display: block;
    margin-top: 1.4rem;
    max-width: 26rem;
    color: var(--ink-muted);
    font-size: 1rem;
    line-height: 1.7;
  }
</style>
