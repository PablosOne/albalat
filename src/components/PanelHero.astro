---
import type { Panel } from '@/data/site';

interface Props {
  panel: Panel;
}

const { panel } = Astro.props;
const headline = panel.heading ?? '';
const subtitle = panel.subheading ?? '';
---
<div
  class="absolute top-14 md:top-16 inset-x-4 md:inset-x-8 bottom-4 md:bottom-8 overflow-hidden rounded-2xl md:rounded-3xl bg-[var(--color-bg)]"
  data-hero-stage
  style="clip-path: inset(0% 0% 100% 0%)"
>
  <img
    src={panel.visual.image}
    alt={panel.visual.imageAlt ?? ''}
    class="absolute inset-0 w-full h-full object-cover object-center"
    loading="eager"
    fetchpriority="high"
    decoding="async"
    data-hero-background
  />

  <div
    class="hero-foreground absolute inset-0 pointer-events-none"
    data-hero-foreground
    style="opacity: 0"
  >
    <img
      src="/images/eulo.webp"
      alt=""
      class="hero-foreground__image"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
  </div>

  <div class="hero-readability-wash" aria-hidden="true"></div>
  <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-black/60 via-black/18 to-transparent pointer-events-none" aria-hidden="true"></div>

  <h1
    class="hero-headline absolute top-[8%] md:top-[10%] left-0 right-0 mx-auto text-center text-display-xl font-display text-white px-6 md:px-12 max-w-[18ch]"
    data-hero-headline
    style="visibility: hidden"
  >
    {headline.split(' ').map((word) => (
      <span class="inline-block overflow-hidden align-top pr-[0.2em] pb-[0.25em]" data-hero-word>
        <span class="inline-block" data-hero-word-text>{word}</span>
      </span>
    ))}
  </h1>

  <div class="absolute z-[2] bottom-16 md:bottom-8 right-4 md:right-10 left-4 md:left-auto flex flex-col items-end gap-3 max-w-[38ch] md:max-w-[38ch]">
    <p
      class="text-label text-white/80 text-right"
      data-hero-subtitle
      style="opacity: 0; clip-path: inset(0% 0% 100% 0%)"
    >
      {subtitle}
    </p>
    <span
      class="hero-signature inline-block text-display-l font-display text-white leading-[1.05] pb-[0.12em] text-right"
      data-hero-signature
      style="opacity: 0; clip-path: inset(0% 0% 100% 0%)"
    >
      {panel.role}
    </span>
  </div>
</div>

<style>
  .hero-foreground {
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }

  .hero-foreground__image {
    display: block;
    width: min(112vw, 1480px);
    max-width: none;
    height: auto;
    transform: translate3d(0, 3%, 0);
    object-fit: contain;
    object-position: center bottom;
  }

  .hero-readability-wash {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      linear-gradient(90deg, rgba(0, 0, 0, 0.5) 0%, rgba(0, 0, 0, 0.22) 28%, transparent 58%),
      linear-gradient(180deg, rgba(0, 0, 0, 0.42) 0%, transparent 34%);
  }

  .hero-headline {
    z-index: 2;
    text-shadow: 0 3px 24px rgba(0, 0, 0, 0.52);
  }

  .hero-signature {
    text-shadow: 0 3px 22px rgba(0, 0, 0, 0.55);
  }

  @media (min-width: 1024px) {
    .hero-foreground {
      justify-content: center;
    }

    .hero-foreground__image {
      width: min(92vw, 1500px);
      transform: translate3d(-4vw, 5%, 0);
    }

    .hero-headline {
      top: clamp(5.5rem, 15vh, 10rem);
      right: auto;
      left: clamp(2rem, 5vw, 6rem);
      max-width: min(9.5ch, 45vw);
      padding-inline: 0;
      text-align: left;
      font-size: clamp(4rem, 7vw, 8.25rem);
      line-height: 0.86;
    }
  }

  @media (min-width: 1440px) {
    .hero-foreground__image {
      width: min(82vw, 1640px);
      transform: translate3d(-5vw, 5%, 0);
    }
  }

  @media (min-width: 1024px) and (max-height: 820px) {
    .hero-foreground__image {
      width: min(86vw, 1440px);
      transform: translate3d(-3vw, 9%, 0);
    }

    .hero-headline {
      top: clamp(4.75rem, 13vh, 7rem);
      font-size: clamp(3.75rem, 6.2vw, 6.8rem);
    }
  }

  @media (max-width: 767px) {
    .hero-readability-wash {
      background:
        linear-gradient(180deg, rgba(0, 0, 0, 0.44) 0%, transparent 32%),
        linear-gradient(0deg, rgba(0, 0, 0, 0.58) 0%, transparent 38%);
    }

    .hero-foreground {
      justify-content: center;
    }

    .hero-foreground__image {
      width: min(150vw, 720px);
      transform: translate3d(0, 3%, 0);
    }

    .hero-signature {
      max-width: 100%;
      font-size: clamp(2.25rem, 12vw, 3.25rem);
      line-height: 0.98;
    }
  }
</style>
