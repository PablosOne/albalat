---
import { site } from '@/data/site';
const pathname = Astro.url.pathname;
const isEnglish = pathname === '/en' || pathname.startsWith('/en/');
const href = pathname === '/' || pathname === '/en/' ? '#hero' : (isEnglish ? '/en/' : '/');
---
<a
  href={href}
  class="hidden md:inline-block font-mono text-xs uppercase tracking-wide text-ink fixed top-6 left-6 z-50 mix-blend-difference focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent rounded-sm"
  aria-label="Home"
>
  {site.fullName}
</a>
