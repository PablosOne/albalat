---
import { site } from '@/data/site';
const pathname = Astro.url.pathname;
const isEnglish = pathname === '/en' || pathname.startsWith('/en/');
const href = pathname === '/' || pathname === '/en/' ? '#hero' : (isEnglish ? '/en/' : '/');
const isHome = pathname === '/' || pathname === '/en/';
const toolbarAttrs = isHome
  ? { 'data-toolbar': true, style: 'opacity: 0; clip-path: inset(0% 0% 100% 0%)' }
  : {};
---
<a
  {...toolbarAttrs}
  href={href}
  class="hidden md:inline-block font-mono text-label text-[var(--color-fg)] fixed top-6 left-6 z-50 mix-blend-difference focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)] rounded-sm"
  aria-label="Home"
>
  {site.fullName}
</a>
