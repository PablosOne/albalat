---
import type { Panel } from '@/data/site';
import TextReveal from './TextReveal.astro';
import LaneArrow from './LaneArrow.astro';

interface Props {
  panel: Panel;
}

const { panel } = Astro.props;
---
<div class="relative w-full h-full" data-about-content>
  <div
    class="about-decorative absolute inset-0 pointer-events-none overflow-visible"
    aria-hidden="true"
  >
    <h2
      class="absolute top-[18%] left-0 w-max max-w-none font-display font-medium leading-[0.92] text-[clamp(40px,8vw,148px)] text-[var(--color-muted)] whitespace-nowrap will-change-transform"
      data-about-headline
    >
      {panel.tagline}
    </h2>
  </div>

  <div class="about-body absolute top-[44%] left-[-3vw] max-w-[56ch]">
    {panel.subheading && (
      <TextReveal as="p" text={panel.subheading} class="text-label text-[var(--color-muted)] mb-5" reveal="heading" mode="block" preset="label" data-parallax-x="-0.32" />
    )}
    <TextReveal as="h3" text={panel.heading} class="about-title text-display-l font-display font-medium leading-[0.95] mb-6 text-[var(--color-fg)]" reveal="heading" mode="words" preset="headline" data-parallax-x="-0.20" />
    <div class="text-body-xl leading-[1.35] max-w-[48ch]" data-parallax-x="-0.10">
      {panel.body.map((paragraph) => (
        <TextReveal as="p" text={paragraph} class="mb-4 text-[var(--color-muted)]" reveal="body" mode="phrases" preset="body" />
      ))}
    </div>
    {panel.detail && panel.openLabel && (
      <div data-reveal="cta" class="mt-8">
        <LaneArrow direction="down" targetId={panel.id} href={panel.href} label={panel.openLabel} withString />
      </div>
    )}
  </div>
</div>

<style>
  /* Fraunces' “g” descender extends farther than the generic word-reveal mask.
     Give this heading a deeper mask so “Biografía” is never cropped while the
     reveal animation remains clipped correctly. */
  :global(.about-title [data-text-reveal-mask]) {
    padding-bottom: 0.28em;
  }

  @media (min-width: 768px) {
    .about-decorative {
      clip-path: inset(-100vh 0 -100vh -200vw);
    }

    :global(.about-title) {
      font-size: clamp(2.75rem, 4vw + 0.5rem, 4.5rem) !important;
    }

    /* Reserve the upper portion of the station for the moving display line.
       A fixed vertical boundary is more reliable than letting the copy grow
       upward into it, especially at intermediate laptop heights. */
    [data-about-content] .about-body {
      top: 39%;
      bottom: auto;
    }
  }

  /* Shorter viewports: shrink type and spacing so the upward-growing block still
     clears the nav at the top. Two tiers keep it fitting down to landscape
     phones / very small laptops. */
  @media (min-width: 768px) and (max-height: 760px) {
    :global(.about-title) {
      font-size: clamp(2.25rem, 3vw + 0.3rem, 3.25rem) !important;
      margin-bottom: 1.1rem !important;
    }
    :global(.about-body .text-label) { margin-bottom: 0.75rem; }
    :global(.about-body .text-body-xl) { font-size: 1.05rem; line-height: 1.3; }
    :global(.about-body .text-body-xl p) { margin-bottom: 0.55rem; }
    .about-body :global([data-reveal="cta"]) { margin-top: 1.25rem; }
  }
  @media (min-width: 768px) and (max-height: 620px) {
    [data-about-content] .about-body { top: 42%; }
    :global(.about-title) {
      font-size: clamp(1.9rem, 2.4vw + 0.3rem, 2.6rem) !important;
      margin-bottom: 0.9rem !important;
    }
    :global(.about-body .text-label) { margin-bottom: 0.5rem; }
    :global(.about-body .text-body-xl) { font-size: 1rem; line-height: 1.25; }
    :global(.about-body .text-body-xl p) { margin-bottom: 0.45rem; }
  }

  @media (min-width: 768px) and (max-height: 500px) {
    [data-about-headline] {
      font-size: clamp(2.5rem, min(8vw, 15vh), 6rem);
    }
  }

  /* Very shallow landscape windows cannot hold the nav, display line, full
     teaser and CTA as four vertical bands. Keep the two signature elements —
     the scrolling line and “Biografía” — plus the route to the full text. */
  @media (min-width: 768px) and (max-height: 460px) {
    [data-about-content] .about-body {
      top: 48%;
    }

    :global(.about-body .text-label),
    :global(.about-body .text-body-xl) {
      display: none;
    }

    :global(.about-title) {
      margin-bottom: 0.65rem !important;
    }

    .about-body :global([data-reveal="cta"]) {
      margin-top: 0.65rem;
    }
  }

  /* Mobile: the desktop layout layers the real heading/body over a giant
     nowrap decorative quote using absolute positioning + horizontal parallax
     bleed (see showcase.desktop.ts, disabled on mobile — see src/lib/showcase.ts).
     That composition has no vertical-stack equivalent, so give this panel its
     own relative-flow layout here instead of leaning on global.css's
     `!important` rescues: real content (subheading, heading, body) reads
     first, and the decorative tagline follows as a smaller, subdued line. */
  @media (max-width: 767px) {
    [data-about-content] {
      display: flex;
      flex-direction: column;
      position: relative;
      height: auto;
      text-align: left;
    }

    [data-about-content]::before {
      content: "";
      width: 4.5rem;
      height: 1px;
      margin-bottom: 1.25rem;
      background: var(--color-accent);
      box-shadow: 0 0 14px color-mix(in srgb, var(--color-accent) 35%, transparent);
    }

    .about-body {
      position: relative;
      top: auto;
      left: auto;
      order: 1;
      width: 100%;
      max-width: 100%;
      padding-inline: 0.75rem;
      text-align: left;
    }

    :global(.about-body .text-label) {
      margin-bottom: 1rem;
      color: var(--color-accent);
      letter-spacing: 0.1em;
    }

    :global(.about-title) {
      max-width: 11ch;
      margin-bottom: 1.5rem !important;
      font-size: clamp(2.75rem, 13vw, 3.65rem) !important;
      line-height: 0.94 !important;
      text-wrap: balance;
    }

    :global(.about-body .text-body-xl) {
      max-width: 31rem;
    }

    :global(.about-body .text-body-xl p) {
      margin-bottom: 1rem;
    }

    .about-decorative {
      position: relative;
      inset: auto;
      order: 2;
      margin-top: 2.25rem;
      width: 100%;
      /* This clip-path is inline on the element (desktop-only horizontal-bleed
         geometry) and harmless once the headline below is width-constrained —
         but disable it explicitly on mobile too, since it serves no purpose
         in normal relative flow and removes any doubt about it clipping text. */
      padding: 1.5rem 0.75rem 0;
      border-top: 1px solid var(--color-border);
    }

    [data-about-headline] {
      position: relative;
      top: auto;
      left: auto;
      width: 100%;
      max-width: 100%;
      white-space: normal;
      overflow-wrap: break-word;
      max-width: 20ch;
      color: var(--color-muted);
      font-size: clamp(1.75rem, 8vw, 2.4rem);
      font-weight: 400;
      line-height: 1.08;
      opacity: 0.78;
      text-align: left;
      text-wrap: balance;
    }
  }
</style>
