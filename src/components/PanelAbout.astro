---
import type { Panel } from '@/data/site';
import TextReveal from './TextReveal.astro';

interface Props {
  panel: Panel;
}

const { panel } = Astro.props;
---
<div class="relative w-full h-full" data-about-content>
  <div
    class="about-decorative absolute inset-0 pointer-events-none overflow-visible"
    style="clip-path: inset(-100vh 0 -100vh -200vw);"
    aria-hidden="true"
  >
    <h2
      class="absolute top-[28%] left-0 w-max max-w-none font-display font-medium leading-[0.92] text-[clamp(40px,8vw,148px)] text-[var(--color-muted)] whitespace-nowrap will-change-transform"
      data-about-headline
    >
      {panel.tagline}
    </h2>
  </div>

  <div class="about-body absolute top-[44%] left-[-3vw] max-w-[56ch]">
    {panel.subheading && (
      <TextReveal as="p" text={panel.subheading} class="text-label text-[var(--color-muted)] mb-5" reveal="heading" mode="block" preset="label" data-parallax-x="-0.32" />
    )}
    <TextReveal as="h3" text={panel.heading} class="about-title text-display-l font-display font-medium leading-[0.95] mb-6 text-[var(--color-fg)]" reveal="heading" mode="words" preset="headline" data-parallax-x="-0.20" />
    <div class="text-body-xl leading-[1.35] max-w-[48ch]" data-parallax-x="-0.10">
      {panel.body.map((paragraph) => (
        <TextReveal as="p" text={paragraph} class="mb-4 text-[var(--color-muted)]" reveal="body" mode="phrases" preset="body" />
      ))}
    </div>
  </div>
</div>

<style>
  @media (min-width: 768px) {
    :global(.about-title) {
      font-size: clamp(2.75rem, 4vw + 0.5rem, 4.5rem) !important;
    }
  }

  /* Mobile: the desktop layout layers the real heading/body over a giant
     nowrap decorative quote using absolute positioning + horizontal parallax
     bleed (see showcase.desktop.ts, disabled on mobile — see src/lib/showcase.ts).
     That composition has no vertical-stack equivalent, so give this panel its
     own relative-flow layout here instead of leaning on global.css's
     `!important` rescues: real content (subheading, heading, body) reads
     first, and the decorative tagline follows as a smaller, subdued line. */
  @media (max-width: 767px) {
    [data-about-content] {
      display: flex;
      flex-direction: column;
      position: relative;
      height: auto;
      padding-top: 0.5rem;
      text-align: left;
    }

    .about-body {
      position: relative;
      top: auto;
      left: auto;
      order: 1;
      width: 100%;
      max-width: 100%;
      text-align: left;
    }

    .about-decorative {
      position: relative;
      inset: auto;
      order: 2;
      margin-top: 2rem;
      width: 100%;
      /* This clip-path is inline on the element (desktop-only horizontal-bleed
         geometry) and harmless once the headline below is width-constrained —
         but disable it explicitly on mobile too, since it serves no purpose
         in normal relative flow and removes any doubt about it clipping text. */
      clip-path: none;
    }

    [data-about-headline] {
      position: relative;
      top: auto;
      left: auto;
      width: 100%;
      max-width: 100%;
      white-space: normal;
      overflow-wrap: break-word;
      font-size: clamp(1.35rem, 6vw, 2rem);
      line-height: 1.2;
      opacity: 0.72;
      text-align: left;
    }
  }
</style>
