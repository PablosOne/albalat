---
import type { Locale } from '@/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const pauseLabel = locale === 'en' ? 'Pause playback' : 'Pausar reproducción';
---

<button
  type="button"
  class="mobile-playback-control"
  data-np-mobile-toggle
  aria-label={pauseLabel}
  hidden
>
  <img data-np-mobile-cover src="" alt="" width="44" height="44" />
  <span class="mobile-playback-control__pause" aria-hidden="true"></span>
</button>

<style>
  .mobile-playback-control {
    display: none;
  }

  @media (max-width: 767px) {
    .mobile-playback-control {
      position: relative;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 3.25rem;
      height: 3.25rem;
      flex: 0 0 3.25rem;
      overflow: hidden;
      padding: 0;
      border: 1px solid rgba(244, 239, 231, 0.2);
      border-radius: 999px;
      background: rgba(11, 10, 9, 0.38);
      color: #f4efe7;
      box-shadow: inset 0 0 0 1px rgba(11, 10, 9, 0.14);
      cursor: pointer;
      transition: border-color 180ms ease, box-shadow 240ms ease, transform 180ms ease;
    }

    .mobile-playback-control[hidden] {
      display: none;
    }

    .mobile-playback-control img {
      position: absolute;
      inset: 0.22rem;
      width: calc(100% - 0.44rem);
      height: calc(100% - 0.44rem);
      border-radius: inherit;
      object-fit: cover;
      filter: brightness(0.64) saturate(0.88);
    }

    .mobile-playback-control__pause {
      position: relative;
      z-index: 1;
      width: 0.62rem;
      height: 0.78rem;
      background: linear-gradient(
        90deg,
        currentColor 0 29%,
        transparent 29% 71%,
        currentColor 71% 100%
      );
      filter: drop-shadow(0 1px 3px rgba(0, 0, 0, 0.72));
    }

    .mobile-playback-control:hover,
    .mobile-playback-control:focus-visible {
      border-color: var(--album-accent, var(--color-accent));
      box-shadow: 0 0 0 0.25rem color-mix(in srgb, var(--album-accent, var(--color-accent)) 22%, transparent);
      outline: none;
      transform: scale(1.035);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-playback-control {
      transition: none;
    }
  }
</style>
