---
import { getHomePanels, type HomeLocale } from '@/data/site';
import Panel from './Panel.astro';
import ShowcaseHUD from './ShowcaseHUD.astro';
import DetailLane from './DetailLane.astro';
import AlbumStoryPlayer from './AlbumStoryPlayer.astro';
import VideoGallery from './VideoGallery.astro';
import AboutContent from './content/AboutContent.astro';
import ClassesContent from './content/ClassesContent.astro';
import { discography } from '@/data/discography';
import { videos } from '@/data/videos';

interface Props {
  locale: HomeLocale;
  initialDetail?: string | null;
}

const { locale, initialDetail = null } = Astro.props;
const panels = getHomePanels(locale);
---
{initialDetail && (
  // data-astro-rerun: without it, Astro's ClientRouter dedupes this script by its
  // exact text (see src/layouts/Base.astro's own astro:page-load fix for the same
  // mechanism) and skips re-running it on a repeat SPA visit to this route within
  // the same session, silently breaking auto-open of the detail lane.
  <script is:inline data-astro-rerun set:html={`document.documentElement.dataset.initialDetail=${JSON.stringify(initialDetail)}`}></script>
)}
<section class="relative w-full overflow-hidden" aria-label={locale === 'en' ? 'Home' : 'Inicio'} data-showcase>
  {/* Dedicated vertical-descent layer. The lane open/close (lanes.ts) drives this
      wrapper's y so the panel row slides up with the detail, WITHOUT touching the
      inner track's transform — which the horizontal scrub (showcase.desktop.ts)
      owns via x. Decoupling the two onto separate elements is what stops them
      fighting (the old cause of the descent only working the first time). Purely a
      transform layer: the track stays `relative` so panel.offsetLeft — which the
      scrub reads — is unchanged, and on mobile it's inert. */}
  <div data-showcase-descent>
    <div class="relative z-10 flex" data-showcase-track style="width: max-content;">
      {panels.map((panel, i) => <Panel panel={panel} isLast={i === panels.length - 1} />)}
    </div>
  </div>
  {['about', 'music', 'videos', 'classes'].map((id) => (
    <DetailLane id={id} title={panels.find((p) => p.id === id)?.heading ?? id} locale={locale}>
      {id === 'about'   && <AboutContent locale={locale} />}
      {id === 'music'   && <AlbumStoryPlayer albums={discography} locale={locale} />}
      {id === 'videos'  && <VideoGallery videos={videos} locale={locale} />}
      {id === 'classes' && <ClassesContent locale={locale} />}
    </DetailLane>
  ))}
  <ShowcaseHUD />
</section>
