---
interface Props {
  locale: 'es' | 'en';
}
const { locale } = Astro.props;
const copy = {
  es: { region: 'Reproductor', play: 'Reproducir', pause: 'Pausar', prev: 'Anterior', next: 'Siguiente',
        full: 'Pista completa', spotify: 'Abrir en Spotify', apple: 'Abrir en Apple Music', youtube: 'Abrir en YouTube', close: 'Cerrar',
        hint: 'Vista previa - pista completa en Spotify / Apple Music', seek: 'Buscar en la pista' },
  en: { region: 'Player', play: 'Play', pause: 'Pause', prev: 'Previous', next: 'Next',
        full: 'Full track', spotify: 'Open in Spotify', apple: 'Open in Apple Music', youtube: 'Open in YouTube', close: 'Close',
        hint: 'Preview - full track on Spotify / Apple Music', seek: 'Seek within track' },
}[locale];
---
<aside
  id="now-playing-bar"
  transition:persist="now-playing"
  data-visible="false"
  hidden
  role="region"
  aria-label={copy.region}
  class="fixed inset-x-0 bottom-0 z-50 border-t border-ink/15 bg-[#0d0c0a]/95 backdrop-blur-md pb-[env(safe-area-inset-bottom)] transition-transform duration-300 data-[visible=false]:translate-y-full"
>
  <div data-np-embed hidden class="border-b border-ink/10 bg-black"></div>
  <div class="mx-auto flex max-w-6xl items-center gap-3 px-4 py-2.5 md:gap-4">
    <img data-np-cover src="" alt="" width="48" height="48" class="size-12 shrink-0 border border-ink/10 object-cover" />
    <div class="min-w-0 flex-1">
      <p data-np-title class="truncate text-sm font-medium text-ink">-</p>
      <div class="mt-1 flex items-center gap-2">
        <span data-np-elapsed class="font-mono text-[0.65rem] text-ink-muted">0:00</span>
        <input data-np-seek type="range" min="0" max="1000" value="0" step="1"
          aria-label={copy.seek}
          class="h-1 w-full flex-1 cursor-pointer appearance-none rounded bg-ink/15 accent-[var(--album-accent,theme(colors.accent))]" />
        <span data-np-duration class="font-mono text-[0.65rem] text-ink-muted">0:30</span>
      </div>
      <p data-np-hint class="mt-0.5 truncate text-[0.6rem] text-ink-muted">{copy.hint}</p>
    </div>
    <div class="np-controls flex shrink-0 items-center gap-1">
      <button data-np-prev type="button" aria-label={copy.prev} class="np-btn">⏮</button>
      <button data-np-toggle type="button" aria-label={copy.play} class="np-btn np-btn--primary">▶</button>
      <button data-np-next type="button" aria-label={copy.next} class="np-btn">⏭</button>
      <button data-np-full type="button" class="np-chip">{copy.full}</button>
      <a data-np-spotify href="#" target="_blank" rel="noreferrer" aria-label={copy.spotify} class="np-btn np-btn--brand">
        <svg class="np-brand-icon" viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="12" cy="12" r="9.5" fill="currentColor" opacity="0.95" />
          <path d="M7.7 9.4c2.9-.8 6.3-.6 8.9.8" fill="none" stroke="var(--color-bg, #0d0c0a)" stroke-width="1.4" stroke-linecap="round" />
          <path d="M8.2 12c2.4-.6 5-.4 7.1.7" fill="none" stroke="var(--color-bg, #0d0c0a)" stroke-width="1.25" stroke-linecap="round" />
          <path d="M8.7 14.4c1.8-.4 3.8-.3 5.4.5" fill="none" stroke="var(--color-bg, #0d0c0a)" stroke-width="1.1" stroke-linecap="round" />
        </svg>
      </a>
      <a data-np-apple href="#" target="_blank" rel="noreferrer" aria-label={copy.apple} class="np-btn np-btn--brand">
        <svg class="np-brand-icon" viewBox="0 0 24 24" aria-hidden="true">
          <path fill="currentColor" d="M16.3 12.3c0-1.8 1.5-2.7 1.6-2.8-.9-1.2-2.2-1.4-2.7-1.4-1.1-.1-2.1.6-2.7.6-.6 0-1.5-.6-2.5-.6-1.3 0-2.5.8-3.2 2-1.4 2.4-.4 6 1 7.9.7 1 1.5 2.1 2.5 2 .9 0 1.3-.6 2.5-.6s1.5.6 2.5.6 1.7-1 2.4-2c.8-1.1 1.1-2.2 1.1-2.3 0 0-2.4-.9-2.5-3.4Z" />
          <path fill="currentColor" d="M14.5 6.9c.5-.7.9-1.6.8-2.5-.8 0-1.7.5-2.3 1.2-.5.6-.9 1.5-.8 2.4.9.1 1.8-.4 2.3-1.1Z" />
        </svg>
      </a>
      <a data-np-youtube href="#" target="_blank" rel="noreferrer" aria-label={copy.youtube} class="np-btn np-btn--brand">
        <svg class="np-brand-icon np-brand-icon--youtube" viewBox="0 0 24 24" aria-hidden="true">
          <path fill="currentColor" d="M21.4 7.3a2.7 2.7 0 0 0-1.9-1.9C17.8 5 12 5 12 5s-5.8 0-7.5.4a2.7 2.7 0 0 0-1.9 1.9A28 28 0 0 0 2.2 12c0 1.6.1 3.2.4 4.7a2.7 2.7 0 0 0 1.9 1.9c1.7.4 7.5.4 7.5.4s5.8 0 7.5-.4a2.7 2.7 0 0 0 1.9-1.9c.3-1.5.4-3.1.4-4.7s-.1-3.2-.4-4.7Z" />
          <path fill="var(--color-bg, #0d0c0a)" d="m10.2 14.9 4.8-2.9-4.8-2.9v5.8Z" />
        </svg>
      </a>
      <button data-np-close type="button" aria-label={copy.close} class="np-btn">✕</button>
    </div>
  </div>
</aside>

<style>
  .np-btn { display: inline-flex; align-items: center; justify-content: center; width: 2rem; height: 2rem;
    border: 1px solid rgba(244,239,231,0.14); color: var(--ink); font-size: 0.8rem; }
  .np-btn:hover, .np-btn:focus-visible { border-color: var(--accent); color: var(--accent); outline: none; }
  .np-btn--primary { border-color: var(--album-accent, var(--accent)); color: var(--album-accent, var(--accent)); }
  .np-btn--brand { font-size: 1rem; }
  .np-brand-icon { width: 1.05rem; height: 1.05rem; display: block; }
  .np-chip { padding: 0 0.6rem; height: 2rem; border: 1px solid rgba(244,239,231,0.14); font-size: 0.7rem; white-space: nowrap; }
  .np-chip:hover, .np-chip:focus-visible { border-color: var(--accent); color: var(--accent); outline: none; }
  .np-brand-icon--youtube { width: 1.2rem; }
  [data-np-apple][hidden], [data-np-youtube][hidden], [data-np-full][hidden] { display: none; }

  @media (prefers-reduced-motion: reduce) {
    #now-playing-bar {
      transition: none;
    }
  }

  @media (max-width: 767px) {
    /* Phone controls live in the navbar/detail header, where they reserve
       space instead of floating over the page. Keep this persisted desktop
       bar mounted as the state owner, but remove its visual box entirely. */
    #now-playing-bar {
      display: none;
    }
  }
</style>

<script>
  import { getNowPlaying, type PlayerState } from '@/lib/nowPlaying';
  import { applyTheme } from '@/lib/trackTheme';
  import { hasConsent, requestConsent } from '@/lib/consent';
  import { activateMusicPlayback, PLAYBACK_CHANGE_EVENT } from '@/lib/mediaPlayback';

  const fmt = (s: number) => {
    if (!Number.isFinite(s)) s = 0;
    const m = Math.floor(s / 60); const r = Math.floor(s % 60);
    return `${m}:${String(r).padStart(2, '0')}`;
  };

  // Full bilingual copy dictionary, inlined here (not read from a data-* attribute on
  // the bar element) because that element carries transition:persist="now-playing":
  // Astro's view-transition swap keeps the OLD persisted node and discards the freshly
  // fetched page's node entirely, so any attribute serialized onto it (e.g. data-copy)
  // is frozen at whatever locale was active when the bar was first mounted. The
  // <html lang> attribute, by contrast, is updated on every navigation by Astro's
  // swapRootAttributes step (it lives outside the persisted subtree), so we resolve
  // the active locale from document.documentElement.lang instead.
  const COPY: Record<'es' | 'en', Record<string, string>> = {
    es: { region: 'Reproductor', play: 'Reproducir', pause: 'Pausar', prev: 'Anterior', next: 'Siguiente',
          full: 'Pista completa', spotify: 'Abrir en Spotify', apple: 'Abrir en Apple Music', youtube: 'Abrir en YouTube', close: 'Cerrar',
          hint: 'Vista previa - pista completa en Spotify / Apple Music', seek: 'Buscar en la pista' },
    en: { region: 'Player', play: 'Play', pause: 'Pause', prev: 'Previous', next: 'Next',
          full: 'Full track', spotify: 'Open in Spotify', apple: 'Open in Apple Music', youtube: 'Open in YouTube', close: 'Close',
          hint: 'Preview - full track on Spotify / Apple Music', seek: 'Seek within track' },
  };

  const currentLocale = (): 'es' | 'en' =>
    document.documentElement.lang.startsWith('en') ? 'en' : 'es';

  let copy: Record<string, string> = {};
  let refreshDynamicCopy: (() => void) | null = null;

  const applyStaticCopy = (bar: HTMLElement) => {
    bar.setAttribute('aria-label', copy.region ?? '');
    bar.querySelector('[data-np-seek]')?.setAttribute('aria-label', copy.seek ?? '');
    const hint = bar.querySelector<HTMLElement>('[data-np-hint]');
    if (hint) hint.textContent = copy.hint ?? '';
    bar.querySelector('[data-np-prev]')?.setAttribute('aria-label', copy.prev ?? '');
    bar.querySelector('[data-np-next]')?.setAttribute('aria-label', copy.next ?? '');
    const full = bar.querySelector<HTMLElement>('[data-np-full]');
    if (full) full.textContent = copy.full ?? '';
    bar.querySelector('[data-np-spotify]')?.setAttribute('aria-label', copy.spotify ?? '');
    bar.querySelector('[data-np-apple]')?.setAttribute('aria-label', copy.apple ?? '');
    bar.querySelector('[data-np-youtube]')?.setAttribute('aria-label', copy.youtube ?? '');
    bar.querySelector('[data-np-close]')?.setAttribute('aria-label', copy.close ?? '');
  };

  const initNowPlayingBar = () => {
    const bar = document.getElementById('now-playing-bar');
    if (!bar) return;

    // The bar node is transition:persist'd across client-side navigations, so it is
    // never re-created. Re-derive the current page's locale from document.documentElement.lang
    // (kept fresh by Astro on every navigation) and re-apply the matching copy to the
    // static chrome on every astro:page-load — independent of the one-time listener
    // binding below — so the bar's labels don't stay stuck in the locale that was
    // active when the node was first mounted.
    copy = COPY[currentLocale()];
    applyStaticCopy(bar);
    refreshDynamicCopy?.();

    if (bar.dataset.bound === 'true') return;
    bar.dataset.bound = 'true';
    const engine = getNowPlaying();

    const q = <T extends Element>(sel: string) => bar.querySelector<T>(sel)!;
    const cover = q<HTMLImageElement>('[data-np-cover]');
    const title = q<HTMLElement>('[data-np-title]');
    const toggle = q<HTMLButtonElement>('[data-np-toggle]');
    const seek = q<HTMLInputElement>('[data-np-seek]');
    const elapsed = q<HTMLElement>('[data-np-elapsed]');
    const duration = q<HTMLElement>('[data-np-duration]');
    const embed = q<HTMLElement>('[data-np-embed]');
    const spotify = q<HTMLAnchorElement>('[data-np-spotify]');
    const apple = q<HTMLAnchorElement>('[data-np-apple]');
    const youtube = q<HTMLAnchorElement>('[data-np-youtube]');
    const full = q<HTMLButtonElement>('[data-np-full]');

    const togglePlayback = () => {
      if (engine.getState().isPaused) activateMusicPlayback();
      engine.toggle();
    };
    toggle.addEventListener('click', togglePlayback);
    document.addEventListener('click', (event) => {
      const target = event.target as Element | null;
      if (target?.closest('[data-np-mobile-toggle]')) togglePlayback();
    });
    q<HTMLButtonElement>('[data-np-prev]').addEventListener('click', () => {
      activateMusicPlayback();
      engine.prev();
    });
    q<HTMLButtonElement>('[data-np-next]').addEventListener('click', () => {
      activateMusicPlayback();
      engine.next();
    });
    q<HTMLButtonElement>('[data-np-close]').addEventListener('click', () => { engine.close(); embed.hidden = true; embed.replaceChildren(); });
    seek.addEventListener('input', () => {
      const s = engine.getState();
      if (s.duration) engine.seek((Number(seek.value) / 1000) * s.duration);
    });
    full.addEventListener('click', () => {
      if (!hasConsent('externalMedia')) {
        requestConsent('externalMedia');
        return;
      }
      const s = engine.getState();
      if (!s.track) return;
      const provider: 'spotify' | 'apple' = s.track.appleEmbed ? 'apple' : 'spotify';
      const src = s.track.appleEmbed
        ?? (s.track.spotifyUri ? `https://open.spotify.com/embed/${s.track.spotifyUri.split(':').slice(1).join('/')}` : null);
      if (!src) return;
      activateMusicPlayback();
      const iframe = document.createElement('iframe');
      iframe.src = src;
      iframe.loading = 'lazy';
      iframe.allow = 'autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture';
      iframe.className = 'h-[152px] w-full border-0 md:h-[232px]';
      embed.replaceChildren(iframe);
      embed.hidden = false;
      engine.expandFull(provider);
    });

    window.addEventListener(PLAYBACK_CHANGE_EVENT, (event) => {
      const kind = (event as CustomEvent<{ kind?: string }>).detail?.kind;
      if (kind !== 'music' && kind !== 'video') return;
      embed.hidden = true;
      embed.replaceChildren();
      if (engine.getState().mode === 'full') engine.collapse();
    });

    const render = (s: PlayerState) => {
      bar.hidden = !s.visible;
      bar.dataset.visible = String(s.visible);
      document.documentElement.toggleAttribute('data-now-playing-active', s.visible && !s.isPaused);
      if (s.mode !== 'full' && !embed.hidden) {
        embed.hidden = true;
        embed.replaceChildren();
      }
      applyTheme('nowplaying', s.visible && s.track ? s.track.theme : null);
      toggle.textContent = s.isPaused ? '▶' : '⏸';
      toggle.setAttribute('aria-label', s.isPaused ? (copy.play ?? 'Play') : (copy.pause ?? 'Pause'));
      document.querySelectorAll<HTMLButtonElement>('[data-np-mobile-toggle]').forEach((control) => {
        control.hidden = s.isPaused || !s.visible || !s.track;
        control.setAttribute('aria-label', copy.pause ?? 'Pause');
        const mobileCover = control.querySelector<HTMLImageElement>('[data-np-mobile-cover]');
        if (mobileCover) mobileCover.src = s.track?.cover ?? '';
      });
      if (!s.track) return;
      cover.src = s.track.cover;
      cover.alt = s.track.albumTitle;
      title.textContent = `${s.track.title} — ${s.track.albumTitle}`;
      elapsed.textContent = fmt(s.position);
      duration.textContent = fmt(s.duration || 30);
      seek.value = String(s.duration ? Math.round((s.position / s.duration) * 1000) : 0);
      seek.setAttribute('aria-valuenow', String(Math.round(s.position)));
      spotify.href = s.track.spotifyUrl ?? '#';
      apple.hidden = !s.track.appleUrl;
      if (s.track.appleUrl) apple.href = s.track.appleUrl;
      youtube.hidden = !s.track.youtubeUrl;
      if (s.track.youtubeUrl) youtube.href = s.track.youtubeUrl;
      full.hidden = !(s.track.appleEmbed || s.track.spotifyUri);
    };

    refreshDynamicCopy = () => render(engine.getState());

    engine.subscribe(render);
    render(engine.getState());
  };

  initNowPlayingBar();
  document.addEventListener('astro:page-load', initNowPlayingBar);
</script>
