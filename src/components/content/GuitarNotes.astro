---
import { guitarNotes } from '@/data/guitar-notes';
import type { Locale } from '@/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const kindLabels = {
  es: {
    trick: 'Tecnica',
    sound: 'Sonido',
    guitars: 'Instrumentos',
  },
  en: {
    trick: 'Technique',
    sound: 'Sound',
    guitars: 'Instruments',
  },
} as const;

const copy = {
  es: {
    eyebrow: 'La guitarra',
    heading: 'Tecnica, sonido e instrumento como una sola conversacion.',
    intro: 'Un cuaderno editorial para reunir observaciones sobre el estudio, la produccion del sonido y la eleccion de la guitarra clasica.',
  },
  en: {
    eyebrow: 'The Guitar',
    heading: 'Technique, sound, and instrument in one conversation.',
    intro: 'An editorial notebook for observations on practice, sound production, and choosing a classical guitar.',
  },
} as const;
---
<section class="px-6 pb-20 pt-32 md:px-10 md:pb-28 md:pt-40">
  <div class="mx-auto max-w-6xl">
    <p data-reveal="label" class="font-mono text-xs font-medium uppercase tracking-wide text-accent">{copy[locale].eyebrow}</p>
    <h1 data-reveal="heading" class="mt-6 max-w-4xl font-display text-5xl font-light leading-tight text-ink md:text-7xl">
      {copy[locale].heading}
    </h1>
    <p data-reveal="body" class="mt-8 max-w-3xl text-lg leading-8 text-ink-muted md:text-xl">
      {copy[locale].intro}
    </p>

    <div class="mt-16 grid gap-6 lg:grid-cols-3">
      {guitarNotes.map((note) => (
        <article class="border border-ink/10 bg-ink/[0.03] p-6">
          <p data-reveal="label" class="font-mono text-xs font-medium uppercase tracking-wide text-accent">{kindLabels[locale][note.kind]}</p>
          <h2 data-reveal="heading" class="mt-5 font-display text-3xl font-light leading-tight text-ink">{note.title[locale]}</h2>
          <p data-reveal="body" class="mt-4 text-base leading-7 text-ink-muted">{note.summary[locale]}</p>
          <div class="mt-7 space-y-5 text-base leading-7 text-ink/85">
            {note.body[locale].map((paragraph) => <p data-reveal="body">{paragraph}</p>)}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
