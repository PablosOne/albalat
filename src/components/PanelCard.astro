---
import type { Panel } from '@/data/site';
import TextReveal from './TextReveal.astro';

interface Props {
  panel: Panel;
}

const { panel } = Astro.props;
---
<div class="grid grid-cols-12 gap-8 w-full max-w-[1600px] mx-auto items-center">
  <div class="col-span-12 lg:col-span-7">
    {panel.role && <TextReveal as="p" text={[panel.role, panel.dates].filter(Boolean).join(' · ')} class="text-label text-[var(--color-muted)] mb-4" reveal="heading" mode="block" preset="label" />}
    <TextReveal as="h2" text={panel.heading} class="text-display-l font-display mb-6" reveal="heading" mode="words" preset="headline" />
    <div class="text-body-xl max-w-[56ch] text-[var(--color-muted)]">
      {panel.body.map((paragraph) => <TextReveal as="p" text={paragraph} class="mb-4" reveal="body" mode="phrases" preset="body" />)}
    </div>
  </div>
  {panel.visual.image && (
    <div class="panel-card__visual col-span-12 lg:col-span-5" data-reveal="visual">
      <div class="panel-card__image aspect-[4/5] overflow-hidden rounded-xl bg-[var(--color-border)]">
        <img src={panel.visual.image} alt={panel.visual.imageAlt ?? ''} class="h-full w-full object-cover" />
      </div>
    </div>
  )}
</div>

<style>
  @media (max-width: 767px) {
    .panel-card__visual {
      margin-top: 0.5rem;
    }

    .panel-card__image {
      aspect-ratio: 4 / 3;
      border: 1px solid color-mix(in srgb, var(--color-fg) 10%, transparent);
      box-shadow: 0 1.25rem 3rem rgba(0, 0, 0, 0.22);
    }
  }
</style>
