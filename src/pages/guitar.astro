---
import Base from '@/layouts/Base.astro';
import Nav from '@/components/Nav.astro';
import Stage from '@/components/Stage.astro';
import { guitarNotes } from '@/data/guitar-notes';
import { site } from '@/data/site';
import { laneSwitch } from '@/lib/transitions';

const locale = 'es';
const title = `${site.fullName} - La guitarra`;
const description = 'Notas de Eulogio Albalat sobre tecnica, sonido, cuerdas e instrumentos de guitarra clasica.';
const pageURL = new URL('/guitar/', Astro.site);
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      '@id': `${pageURL}#webpage`,
      url: pageURL.toString(),
      name: title,
      description,
      inLanguage: 'es',
      breadcrumb: { '@id': `${pageURL}#breadcrumb` },
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${pageURL}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Inicio', item: new URL('/', Astro.site).toString() },
        { '@type': 'ListItem', position: 2, name: 'La guitarra', item: pageURL.toString() },
      ],
    },
    ...guitarNotes.map((note) => ({
      '@type': 'Article',
      '@id': `${pageURL}#${note.id}`,
      headline: note.title.es,
      description: note.summary.es,
      inLanguage: 'es',
      author: { '@type': 'Person', name: site.fullName },
      mainEntityOfPage: { '@id': `${pageURL}#webpage` },
    })),
  ],
};
---
<Base locale={locale} title={title} description={description} jsonLd={jsonLd}>
  <Nav locale="es" />
  <main id="main-content" transition:name="page-lane" transition:animate={laneSwitch}>
    <Stage locale="es" initialDetail="guitar" />
  </main>
</Base>
