---
import Base from '@/layouts/Base.astro';
import Nav from '@/components/Nav.astro';
import Showcase from '@/components/Showcase.astro';
import { site } from '@/data/site';
import { laneSwitch } from '@/lib/transitions';

const locale = 'es';
const title = `${site.fullName} - Masterclass, conciertos y contacto`;
const description = 'Masterclass de guitarra clásica, propuestas de concierto y contacto directo con Eulogio Albalat.';
const pageURL = new URL('/classes/', Astro.site);
const email = site.socials.find((social) => social.href.startsWith('mailto:'))?.href.replace('mailto:', '') ?? 'hello@eulogioalbalat.com';
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ContactPage',
      '@id': `${pageURL}#webpage`,
      url: pageURL.toString(),
      name: title,
      description,
      inLanguage: 'es',
      breadcrumb: { '@id': `${pageURL}#breadcrumb` },
      about: { '@type': 'Person', name: site.fullName, email },
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${pageURL}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Inicio', item: new URL('/', Astro.site).toString() },
        { '@type': 'ListItem', position: 2, name: 'Masterclass y conciertos', item: pageURL.toString() },
      ],
    },
    {
      '@type': 'Course',
      '@id': `${pageURL}#masterclass`,
      name: 'Masterclass de guitarra clásica',
      description: 'Masterclass de guitarra clásica adaptadas al nivel, repertorio y objetivos de cada alumno.',
      provider: { '@type': 'Person', name: site.fullName },
      inLanguage: 'es',
    },
    {
      '@type': 'Service',
      '@id': `${pageURL}#concert-booking`,
      name: 'Conciertos de guitarra clásica',
      description: 'Programas de concierto desde J. S. Bach hasta el siglo XX, con especialización en repertorio español.',
      provider: { '@type': 'Person', name: site.fullName },
      serviceType: 'Classical guitar performance',
      inLanguage: 'es',
    },
  ],
};
---
<Base locale={locale} title={title} description={description} jsonLd={jsonLd}>
  <Nav locale="es" />
  <main id="main-content" transition:name="page-lane" transition:animate={laneSwitch}>
    <Showcase locale="es" initialDetail="classes" />
  </main>
</Base>
