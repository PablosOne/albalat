---
import InquiryForm from '@/components/InquiryForm.astro';
import { site } from '@/data/site';
import Detail from '@/layouts/Detail.astro';

const locale = 'es';
const title = `${site.fullName} - Clases y conciertos`;
const description = 'Clases privadas de guitarra clasica y consultas para conciertos con Eulogio Albalat.';
const pageURL = new URL('/classes/', Astro.site);
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      '@id': `${pageURL}#webpage`,
      url: pageURL.toString(),
      name: title,
      description,
      inLanguage: 'es',
      breadcrumb: { '@id': `${pageURL}#breadcrumb` },
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${pageURL}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Inicio', item: new URL('/', Astro.site).toString() },
        { '@type': 'ListItem', position: 2, name: 'Clases y conciertos', item: pageURL.toString() },
      ],
    },
    {
      '@type': 'Course',
      '@id': `${pageURL}#private-classes`,
      name: 'Clases privadas de guitarra clasica',
      description: 'Clases privadas de guitarra clasica adaptadas al nivel, repertorio y objetivos de cada alumno.',
      provider: { '@type': 'Person', name: site.fullName },
      inLanguage: 'es',
    },
    {
      '@type': 'Service',
      '@id': `${pageURL}#concert-booking`,
      name: 'Conciertos de guitarra clasica',
      description: 'Consultas para recitales, conciertos privados y propuestas musicales.',
      provider: { '@type': 'Person', name: site.fullName },
      serviceType: 'Classical guitar performance',
      inLanguage: 'es',
    },
  ],
};
---
<Detail locale={locale} title={title} description={description} jsonLd={jsonLd}>
  <section class="px-6 pb-20 pt-32 md:px-10 md:pb-28 md:pt-40">
    <div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-[minmax(0,1fr)_420px]">
      <div>
        <p class="font-mono text-xs font-medium uppercase tracking-wide text-accent">Clases y conciertos</p>
        <h1 class="mt-6 max-w-4xl font-display text-5xl font-light leading-tight text-ink md:text-7xl">
          Un espacio para estudiar la guitarra o proponer un concierto.
        </h1>
        <p class="mt-8 max-w-3xl text-lg leading-8 text-ink-muted md:text-xl">
          Las consultas se atienden de forma personal, con atencion al nivel, el repertorio, el calendario y el contexto de cada propuesta.
        </p>

        <div class="mt-14 grid gap-6 md:grid-cols-2">
          <article class="border border-ink/10 p-6">
            <h2 class="font-display text-3xl font-light text-ink">Clases privadas</h2>
            <p class="mt-4 leading-7 text-ink-muted">
              Trabajo tecnico y musical para estudiantes de distintos niveles: sonido, lectura, repertorio, estudio diario y preparacion de obras.
            </p>
          </article>
          <article class="border border-ink/10 p-6">
            <h2 class="font-display text-3xl font-light text-ink">Conciertos</h2>
            <p class="mt-4 leading-7 text-ink-muted">
              Recitales y programas de guitarra clasica para ciclos, espacios culturales, eventos privados y propuestas especiales.
            </p>
          </article>
        </div>
      </div>

      <aside class="lg:pt-16">
        <h2 class="mb-5 font-display text-3xl font-light text-ink">Enviar una consulta</h2>
        <InquiryForm locale={locale} intent="class" />
      </aside>
    </div>
  </section>
</Detail>
