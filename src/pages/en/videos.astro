---
import Base from '@/layouts/Base.astro';
import Nav from '@/components/Nav.astro';
import Showcase from '@/components/Showcase.astro';
import { site } from '@/data/site';
import { videos } from '@/data/videos';
import { laneSwitch } from '@/lib/transitions';

const locale = 'en';
const title = `${site.fullName} - Videos`;
const description = 'Videos by Eulogio Albalat: performances, concerts, and classical guitar recordings.';
const pageURL = new URL('/en/videos/', Astro.site);
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      '@id': `${pageURL}#breadcrumb`,
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: new URL('/en/', Astro.site).toString(),
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Videos',
          item: pageURL.toString(),
        },
      ],
    },
    ...videos.map((video) => ({
      '@type': 'VideoObject',
      '@id': `${pageURL}#${video.id}`,
      name: video.title.en,
      description: video.description?.en ?? video.title.en,
      thumbnailUrl: [`https://i.ytimg.com/vi/${video.youtubeId}/maxresdefault.jpg`],
      embedUrl: `https://www.youtube-nocookie.com/embed/${video.youtubeId}`,
      uploadDate: video.date,
      inLanguage: 'en',
    })),
  ],
};
---
<Base locale={locale} title={title} description={description} jsonLd={jsonLd}>
  <Nav locale="en" />
  <main id="main-content" transition:name="page-lane" transition:animate={laneSwitch}>
    <Showcase locale="en" initialDetail="videos" />
  </main>
</Base>
