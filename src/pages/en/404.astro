---
import Base from '@/layouts/Base.astro';
import Nav from '@/components/Nav.astro';
import { site } from '@/data/site';
import { siteConfig } from '@/config/site';

const title = `${site.fullName} - Page not found`;
const description = `The requested page does not exist. Return to ${siteConfig.identity.name}'s main stage.`;
---
<Base locale="en" title={title} description={description} noIndex>
  <Nav locale="en" />
  <main id="main-content" class="min-h-dvh bg-stage px-6 py-28 text-ink md:px-10 md:py-36">
    <section class="mx-auto flex min-h-[62dvh] max-w-5xl flex-col justify-center">
      <p class="font-mono text-xs font-medium uppercase tracking-wide text-accent">404</p>
      <h1 class="mt-6 max-w-3xl font-display text-5xl font-light leading-tight md:text-7xl">
        This page is no longer on the program.
      </h1>
      <p class="mt-8 max-w-2xl text-lg leading-8 text-ink-muted md:text-xl">
        The address does not match a published section. You can return home or continue in Spanish.
      </p>
      <div class="mt-12 flex flex-wrap gap-3">
        <a
          href="/en/"
          class="rounded-full bg-accent px-5 py-3 text-sm font-semibold text-stage transition-colors duration-200 hover:bg-ink hover:text-stage focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent"
        >
          Return home
        </a>
        <a
          href="/"
          class="rounded-full border border-ink/15 px-5 py-3 text-sm font-semibold text-ink-muted transition-colors duration-200 hover:border-accent hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent"
        >
          Espanol
        </a>
      </div>
    </section>
  </main>
</Base>
