---
import Base from '@/layouts/Base.astro';
import Nav from '@/components/Nav.astro';
import Showcase from '@/components/Showcase.astro';
import { site } from '@/data/site';
import { laneSwitch } from '@/lib/transitions';

const locale = 'en';
const title = `${site.fullName} - Masterclass, Concerts & Contact`;
const description = 'Classical guitar masterclasses, concert inquiries, and direct contact with Eulogio Albalat.';
const pageURL = new URL('/en/classes/', Astro.site);
const email = site.socials.find((social) => social.href.startsWith('mailto:'))?.href.replace('mailto:', '') ?? 'hello@eulogioalbalat.com';
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ContactPage',
      '@id': `${pageURL}#webpage`,
      url: pageURL.toString(),
      name: title,
      description,
      inLanguage: 'en',
      breadcrumb: { '@id': `${pageURL}#breadcrumb` },
      about: { '@type': 'Person', name: site.fullName, email },
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${pageURL}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/en/', Astro.site).toString() },
        { '@type': 'ListItem', position: 2, name: 'Masterclass & Concerts', item: pageURL.toString() },
      ],
    },
    {
      '@type': 'Course',
      '@id': `${pageURL}#masterclass`,
      name: 'Classical guitar masterclasses',
      description: 'Classical guitar masterclasses shaped around each student level, repertoire, and goals.',
      provider: { '@type': 'Person', name: site.fullName },
      inLanguage: 'en',
    },
    {
      '@type': 'Service',
      '@id': `${pageURL}#concert-booking`,
      name: 'Classical guitar concerts',
      description: 'Concert programs from J. S. Bach to the twentieth century, with a specialism in Spanish repertoire.',
      provider: { '@type': 'Person', name: site.fullName },
      serviceType: 'Classical guitar performance',
      inLanguage: 'en',
    },
  ],
};
---
<Base locale={locale} title={title} description={description} jsonLd={jsonLd}>
  <Nav locale="en" />
  <main id="main-content" transition:name="page-lane" transition:animate={laneSwitch}>
    <Showcase locale="en" initialDetail="classes" />
  </main>
</Base>
