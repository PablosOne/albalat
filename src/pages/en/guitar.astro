---
import Base from '@/layouts/Base.astro';
import Nav from '@/components/Nav.astro';
import Stage from '@/components/Stage.astro';
import { guitarNotes } from '@/data/guitar-notes';
import { site } from '@/data/site';
import { laneSwitch } from '@/lib/transitions';

const locale = 'en';
const title = `${site.fullName} - The Guitar`;
const description = 'Notes by Eulogio Albalat on classical guitar technique, sound, strings, and instruments.';
const pageURL = new URL('/en/guitar/', Astro.site);
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      '@id': `${pageURL}#webpage`,
      url: pageURL.toString(),
      name: title,
      description,
      inLanguage: 'en',
      breadcrumb: { '@id': `${pageURL}#breadcrumb` },
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${pageURL}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/en/', Astro.site).toString() },
        { '@type': 'ListItem', position: 2, name: 'The Guitar', item: pageURL.toString() },
      ],
    },
    ...guitarNotes.map((note) => ({
      '@type': 'Article',
      '@id': `${pageURL}#${note.id}`,
      headline: note.title.en,
      description: note.summary.en,
      inLanguage: 'en',
      author: { '@type': 'Person', name: site.fullName },
      mainEntityOfPage: { '@id': `${pageURL}#webpage` },
    })),
  ],
};
---
<Base locale={locale} title={title} description={description} jsonLd={jsonLd}>
  <Nav locale="en" />
  <main id="main-content" transition:name="page-lane" transition:animate={laneSwitch}>
    <Stage locale="en" initialDetail="guitar" />
  </main>
</Base>
