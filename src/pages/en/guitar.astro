---
import { guitarNotes } from '@/data/guitar-notes';
import { site } from '@/data/site';
import Detail from '@/layouts/Detail.astro';

const locale = 'en';
const title = `${site.fullName} - The Guitar`;
const description = 'Notes by Eulogio Albalat on classical guitar technique, sound, strings, and instruments.';
const pageURL = new URL('/en/guitar/', Astro.site);
const kindLabels = {
  trick: 'Technique',
  sound: 'Sound',
  guitars: 'Instruments',
};
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      '@id': `${pageURL}#webpage`,
      url: pageURL.toString(),
      name: title,
      description,
      inLanguage: 'en',
      breadcrumb: { '@id': `${pageURL}#breadcrumb` },
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${pageURL}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/en/', Astro.site).toString() },
        { '@type': 'ListItem', position: 2, name: 'The Guitar', item: pageURL.toString() },
      ],
    },
    ...guitarNotes.map((note) => ({
      '@type': 'Article',
      '@id': `${pageURL}#${note.id}`,
      headline: note.title.en,
      description: note.summary.en,
      inLanguage: 'en',
      author: { '@type': 'Person', name: site.fullName },
      mainEntityOfPage: { '@id': `${pageURL}#webpage` },
    })),
  ],
};
---
<Detail locale={locale} title={title} description={description} jsonLd={jsonLd}>
  <section class="px-6 pb-20 pt-32 md:px-10 md:pb-28 md:pt-40">
    <div class="mx-auto max-w-6xl">
      <p class="font-mono text-xs font-medium uppercase tracking-wide text-accent">The Guitar</p>
      <h1 class="mt-6 max-w-4xl font-display text-5xl font-light leading-tight text-ink md:text-7xl">
        Technique, sound, and instrument in one conversation.
      </h1>
      <p class="mt-8 max-w-3xl text-lg leading-8 text-ink-muted md:text-xl">
        An editorial notebook for observations on practice, sound production, and choosing a classical guitar.
      </p>

      <div class="mt-16 grid gap-6 lg:grid-cols-3">
        {guitarNotes.map((note) => (
          <article class="border border-ink/10 bg-ink/[0.03] p-6">
            <p class="font-mono text-xs font-medium uppercase tracking-wide text-accent">{kindLabels[note.kind]}</p>
            <h2 class="mt-5 font-display text-3xl font-light leading-tight text-ink">{note.title.en}</h2>
            <p class="mt-4 text-base leading-7 text-ink-muted">{note.summary.en}</p>
            <div class="mt-7 space-y-5 text-base leading-7 text-ink/85">
              {note.body.en.map((paragraph) => <p>{paragraph}</p>)}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Detail>
