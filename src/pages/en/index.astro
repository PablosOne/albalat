---
import Base from '@/layouts/Base.astro';
import Nav from '@/components/Nav.astro';
import Stage from '@/components/Stage.astro';
import { site } from '@/data/site';
import { laneSwitch } from '@/lib/transitions';

const pageURL = new URL('/en/', Astro.site);
const imageURL = new URL(site.about.portrait.src, Astro.site);
const sameAs = site.socials.map((social) => social.href).filter((href) => href.startsWith('http'));
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': `${pageURL}#person`,
      name: site.fullName,
      jobTitle: site.role.en,
      url: pageURL.toString(),
      image: imageURL.toString(),
      sameAs,
    },
    {
      '@type': 'MusicGroup',
      '@id': `${pageURL}#artist`,
      name: site.fullName,
      url: pageURL.toString(),
      image: imageURL.toString(),
      member: { '@id': `${pageURL}#person` },
      sameAs,
    },
  ],
};
---
<Base
  locale="en"
  title={`${site.fullName} - ${site.role.en}`}
  description="Eulogio Albalat's digital stage: classical guitar, recordings, videos, private classes, and concerts."
  jsonLd={jsonLd}
>
  <Nav locale="en" />
  <main id="main-content" transition:name="page-lane" transition:animate={laneSwitch}>
    <Stage locale="en" />
  </main>
</Base>
