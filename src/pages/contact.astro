---
import InquiryForm from '@/components/InquiryForm.astro';
import { site } from '@/data/site';
import Detail from '@/layouts/Detail.astro';

const locale = 'es';
const title = `${site.fullName} - Contacto`;
const description = 'Contacto de Eulogio Albalat para clases, conciertos, grabaciones y consultas profesionales.';
const pageURL = new URL('/contact/', Astro.site);
const profileLinks = site.socials.filter((social) => social.href.startsWith('http'));
const email = site.socials.find((social) => social.href.startsWith('mailto:'))?.href.replace('mailto:', '') ?? 'contacto@example.com';
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ContactPage',
      '@id': `${pageURL}#webpage`,
      url: pageURL.toString(),
      name: title,
      description,
      inLanguage: 'es',
      breadcrumb: { '@id': `${pageURL}#breadcrumb` },
      about: { '@type': 'Person', name: site.fullName, email },
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${pageURL}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Inicio', item: new URL('/', Astro.site).toString() },
        { '@type': 'ListItem', position: 2, name: 'Contacto', item: pageURL.toString() },
      ],
    },
  ],
};
---
<Detail locale={locale} title={title} description={description} jsonLd={jsonLd}>
  <section class="px-6 pb-20 pt-32 md:px-10 md:pb-28 md:pt-40">
    <div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-[minmax(0,1fr)_420px]">
      <div>
        <p class="font-mono text-xs font-medium uppercase tracking-wide text-accent">Contacto</p>
        <h1 class="mt-6 max-w-4xl font-display text-5xl font-light leading-tight text-ink md:text-7xl">
          Para conciertos, clases o cualquier consulta profesional.
        </h1>
        <p class="mt-8 max-w-3xl text-lg leading-8 text-ink-muted md:text-xl">
          Puedes escribir mediante el formulario o usar los enlaces directos. Sera un placer conocer el contexto de tu propuesta.
        </p>

        <div class="mt-12 flex flex-wrap gap-3">
          <a class="rounded-full border border-ink/15 px-4 py-2 text-sm font-medium text-ink-muted hover:border-accent hover:text-accent" href={`mailto:${email}`}>
            {email}
          </a>
          {profileLinks.map((social) => (
            <a class="rounded-full border border-ink/15 px-4 py-2 text-sm font-medium text-ink-muted hover:border-accent hover:text-accent" href={social.href} target="_blank" rel="noreferrer">
              {social.label}
            </a>
          ))}
        </div>
      </div>

      <aside class="lg:pt-16">
        <h2 class="mb-5 font-display text-3xl font-light text-ink">Mensaje directo</h2>
        <InquiryForm locale={locale} intent="contact" />
      </aside>
    </div>
  </section>
</Detail>
