---
import '@/styles/global.css';
import Seo from '@/components/Seo.astro';
import NowPlayingBar from '@/components/NowPlayingBar.astro';
import type { Locale } from '@/i18n';
import { ClientRouter } from 'astro:transitions';

interface Props {
  locale: Locale;
  title: string;
  description: string;
  ogImage?: string;
  jsonLd?: object | object[];
}
const { locale } = Astro.props;
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0B0A09" />
    <meta name="application-name" content="Eulogio Albalat" />
    <meta name="apple-mobile-web-app-title" content="Eulogio Albalat" />
    <meta name="format-detection" content="telephone=no" />

    <Seo {...Astro.props} />
    <ClientRouter />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <!-- Font preloads -->
    <link rel="preload" as="font" type="font/woff2" crossorigin href="/fonts/Fraunces-Variable.woff2" />
    <link rel="preload" as="font" type="font/woff2" crossorigin href="/fonts/Geist-Regular.woff2" />
    <link rel="preload" as="font" type="font/woff2" crossorigin href="/fonts/Geist-Medium.woff2" />
    <link rel="preload" as="font" type="font/woff2" crossorigin href="/fonts/Geist-SemiBold.woff2" />

    <!-- Cloudflare Web Analytics (loads only when a beacon token is set) -->
    {import.meta.env.PUBLIC_CF_BEACON && (
      <script is:inline defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon={`{"token": "${import.meta.env.PUBLIC_CF_BEACON}"}`}></script>
    )}
  </head>
  <body>
    <slot />
    <NowPlayingBar locale={locale} />
    <script>
      import { initScroll } from '@/lib/scroll';
      import { heroEntrance } from '@/lib/motion';
      import { initShowcase } from '@/lib/showcase';
      import { initLanes } from '@/lib/lanes';
      import { initSignature } from '@/lib/string';

      // This script's text is identical on every route, so Astro's ClientRouter
      // treats it as "already ran" after the first load and will not re-execute
      // it on later swaps (see astro's transitions/swap-functions.js
      // detectScriptExecuted, keyed by exact script text). initScroll/initShowcase/
      // initLanes/initSignature all bind to the (fresh, swapped-in) DOM though, so
      // they must be torn down and re-run on every astro:page-load, the same way
      // AlbumStoryPlayer.astro and NowPlayingBar.astro already do for their own init.
      let teardown: Array<() => void> = [];
      // On first load, run() fires twice (see below) — once immediately/on
      // DOMContentLoaded, once more from astro:page-load (which the router also
      // dispatches off the native `load` event). If the second fire lands while
      // the first is still suspended on initScroll/initShowcase's dynamic
      // import(), both would otherwise finish and double-init. Only the call that
      // is still current when its awaits resolve gets to register its teardown;
      // a superseded call tears itself down immediately instead.
      let runGen = 0;
      // The cinematic hero intro should play once per session, not once per
      // script-execution: every route's markup ships its hero/toolbar pre-hidden,
      // so each navigation needs *some* reveal or the new page stays permanently
      // clipped/invisible. Only the winning run() call (see gen check below)
      // flips this, so a superseded double-fire on first load can't burn the
      // one real reveal on a call that immediately tears itself down.
      let heroIntroPlayed = false;

      const run = async () => {
        const gen = ++runGen;
        teardown.forEach((fn) => fn());
        teardown = [];

        const initialDetail = document.documentElement.dataset.initialDetail || null;
        const cleanups = [await initScroll(), await initShowcase(), initSignature(), initLanes({ initialDetail })];

        if (gen !== runGen) {
          cleanups.forEach((fn) => fn());
          return;
        }
        teardown = cleanups;
        heroEntrance(document, { instant: heroIntroPlayed });
        heroIntroPlayed = true;
      };

      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', run);
      else run();
      document.addEventListener('astro:page-load', run);
    </script>
  </body>
</html>
