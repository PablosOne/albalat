---
import '@/styles/global.css';
import Seo from '@/components/Seo.astro';
import type { Locale } from '@/i18n';

interface Props {
  locale: Locale;
  title: string;
  description: string;
  ogImage?: string;
  jsonLd?: object;
}
const { locale } = Astro.props;
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0B0A09" />

    <Seo {...Astro.props} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <!-- Font preloads -->
    <link rel="preload" as="font" type="font/woff2" crossorigin href="/fonts/Fraunces-Variable.woff2" />
    <link rel="preload" as="font" type="font/woff2" crossorigin href="/fonts/Geist-Regular.woff2" />
    <link rel="preload" as="font" type="font/woff2" crossorigin href="/fonts/Geist-Medium.woff2" />
    <link rel="preload" as="font" type="font/woff2" crossorigin href="/fonts/Geist-SemiBold.woff2" />

    <!-- Cloudflare Web Analytics (loads only when a beacon token is set) -->
    {import.meta.env.PUBLIC_CF_BEACON && (
      <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon={`{"token": "${import.meta.env.PUBLIC_CF_BEACON}"}`}></script>
    )}
  </head>
  <body>
    <slot />
    <script>
      import { initScroll } from '@/lib/scroll';
      import { heroEntrance } from '@/lib/motion';
      import { initShowcase } from '@/lib/showcase';
      import { initAnchorScroll } from '@/lib/anchorScroll';
      import { initSignature } from '@/lib/string';
      initScroll(); initAnchorScroll();
      const run = () => { heroEntrance(); initShowcase(); initSignature(); };
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', run);
      else run();
    </script>
  </body>
</html>
